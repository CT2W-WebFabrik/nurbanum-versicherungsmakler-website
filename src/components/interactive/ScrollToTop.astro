<button
  id="scroll-to-top"
  type="button"
  class="fixed bottom-20 right-4 sm:bottom-[5.5rem] sm:right-6 z-40 w-11 h-11 bg-navy-900/80 hover:bg-navy-800 backdrop-blur-sm rounded-full flex items-center justify-center shadow-lg transition-all hover:scale-110 print:hidden opacity-0 pointer-events-none"
  aria-label="Nach oben scrollen"
>
  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
  </svg>
</button>

<script>
  const btn = document.getElementById('scroll-to-top');
  if (btn) {
    let visible = false;
    const toggle = () => {
      const show = window.scrollY > 400;
      if (show !== visible) {
        visible = show;
        btn.style.opacity = show ? '1' : '0';
        btn.style.pointerEvents = show ? 'auto' : 'none';
      }
    };
    window.addEventListener('scroll', toggle, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
