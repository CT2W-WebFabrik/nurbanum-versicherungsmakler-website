---
import { url } from '../utils/paths';

interface Props {
  items: { label: string; href: string }[];
  current: string;
}

const { items, current } = Astro.props;
---

<nav aria-label="Brotkrümelnavigation" class="mb-8">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-slate-500">
    <li>
      <a href={url('/')} class="hover:text-amber-600 transition-colors no-underline">Startseite</a>
    </li>
    {items.map((item) => (
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href={url(item.href)} class="hover:text-amber-600 transition-colors no-underline">{item.label}</a>
      </li>
    ))}
    <li class="flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-navy-800 font-medium truncate max-w-[200px] sm:max-w-none" aria-current="page">{current}</span>
    </li>
  </ol>
</nav>
