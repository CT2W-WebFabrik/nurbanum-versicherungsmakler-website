---
import { url } from '../../utils/paths';

const currentYear = new Date().getFullYear();

const insuranceLinks = [
  { href: url('/versicherungen/haftpflicht/'), label: 'Privathaftpflicht' },
  { href: url('/versicherungen/berufsunfaehigkeit/'), label: 'Berufsunfähigkeit' },
  { href: url('/versicherungen/kfz/'), label: 'Kfz-Versicherung' },
  { href: url('/versicherungen/hausrat/'), label: 'Hausratversicherung' },
  { href: url('/versicherungen/wohngebaeude/'), label: 'Wohngebäudeversicherung' },
  { href: url('/versicherungen/rechtsschutz/'), label: 'Rechtsschutzversicherung' },
];

const specialLinks = [
  { href: url('/spezialisierungen/altersvorsorge/'), label: 'Private Altersvorsorge' },
  { href: url('/spezialisierungen/betriebliche-altersversorgung/'), label: 'Betriebliche Altersversorgung' },
  { href: url('/spezialisierungen/ruhestandsplanung/'), label: 'Ruhestandsplanung' },
];
---

<footer class="bg-navy-950 text-navy-300 border-t border-navy-800/50" role="contentinfo">
  <!-- Main footer -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center">
            <span class="text-navy-950 font-display font-900 text-lg leading-none">N</span>
          </div>
          <div>
            <span class="text-white font-display font-800 text-lg">Nurbanum</span>
            <span class="block text-navy-300 text-xs -mt-0.5">Versicherungsmakler</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-5">
          Unabhängige Versicherungsberatung in Zirndorf bei Nürnberg. Persönlich, kompetent, transparent.
        </p>
        <div class="space-y-2 text-sm">
          <a href="tel:+4917384444426" class="flex items-center gap-2 text-navy-300 hover:text-amber-400 transition-colors no-underline">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            0173 8444 4426
          </a>
          <a href="mailto:thorsten.schreier@nurbanum.de" class="flex items-center gap-2 text-navy-300 hover:text-amber-400 transition-colors no-underline">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            thorsten.schreier@nurbanum.de
          </a>
        </div>
      </div>

      <!-- Insurance links -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Versicherungen</h3>
        <ul class="space-y-2.5">
          {insuranceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">{link.label}</a>
            </li>
          ))}
          <li>
            <a href={url('/versicherungen/')} class="text-sm text-amber-500 hover:text-amber-400 transition-colors no-underline font-medium">Alle ansehen →</a>
          </li>
        </ul>
      </div>

      <!-- Specializations -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Spezialisierungen</h3>
        <ul class="space-y-2.5">
          {specialLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">{link.label}</a>
            </li>
          ))}
        </ul>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mt-8 mb-4">Informationen</h3>
        <ul class="space-y-2.5">
          <li><a href={url('/ratgeber/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Ratgeber & Tipps</a></li>
          <li><a href={url('/faq/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Häufige Fragen</a></li>
          <li><a href={url('/glossar/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Versicherungs-Glossar</a></li>
          <li><a href={url('/ueber-uns/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Über uns</a></li>
        </ul>
      </div>

      <!-- Legal + Social -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Rechtliches</h3>
        <ul class="space-y-2.5">
          <li><a href={url('/impressum/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Impressum</a></li>
          <li><a href={url('/datenschutz/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Datenschutzerklärung</a></li>
          <li><a href={url('/erstinformation/')} class="text-sm text-navy-300 hover:text-amber-400 transition-colors no-underline">Erstinformation</a></li>
        </ul>

        <h3 class="text-white font-bold text-sm uppercase tracking-wider mt-8 mb-4">Folgen Sie uns</h3>
        <p class="text-xs text-navy-400 mb-3">Profile folgen in Kürze</p>
        <div class="flex gap-3">
          <span class="w-9 h-9 rounded-lg bg-navy-800/30 flex items-center justify-center text-navy-400" aria-label="Instagram (demnächst verfügbar)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </span>
          <span class="w-9 h-9 rounded-lg bg-navy-800/30 flex items-center justify-center text-navy-400" aria-label="LinkedIn (demnächst verfügbar)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </span>
          <span class="w-9 h-9 rounded-lg bg-navy-800/30 flex items-center justify-center text-navy-400" aria-label="Facebook (demnächst verfügbar)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-navy-800/30">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-navy-400">
      <span>&copy; {currentYear} Nurbanum Versicherungsmakler — Thorsten Schreier. Alle Rechte vorbehalten.</span>
      <span>IHK-registrierter Versicherungsmakler nach §34d GewO</span>
    </div>
  </div>
</footer>
