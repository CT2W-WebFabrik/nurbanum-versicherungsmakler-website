---
import { url } from '../../utils/paths';

const currentPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function isActive(href: string): boolean {
  const home = basePath + '/';
  if (href === home || href === basePath) return currentPath === home || currentPath === basePath;
  return currentPath.startsWith(href);
}

const currentYear = new Date().getFullYear();

const privatLinks = [
  { href: url('/versicherungen/haftpflicht/'), label: 'Privathaftpflicht' },
  { href: url('/versicherungen/berufsunfaehigkeit/'), label: 'Berufsunfähigkeit' },
  { href: url('/versicherungen/kfz/'), label: 'Kfz-Versicherung' },
  { href: url('/versicherungen/hausrat/'), label: 'Hausratversicherung' },
  { href: url('/versicherungen/wohngebaeude/'), label: 'Wohngebäudeversicherung' },
  { href: url('/versicherungen/rechtsschutz/'), label: 'Rechtsschutzversicherung' },
];

const gewerbeLinks = [
  { href: url('/versicherungen/betriebshaftpflicht/'), label: 'Betriebshaftpflicht' },
  { href: url('/versicherungen/berufshaftpflicht/'), label: 'Berufshaftpflicht' },
  { href: url('/versicherungen/dno-versicherung/'), label: 'D&O-Versicherung' },
  { href: url('/versicherungen/cyber/'), label: 'Cyber-Versicherung' },
];

const privatSpecialLinks = [
  { href: url('/spezialisierungen/berufseinsteiger-junge-erwachsene/'), label: 'Berufseinsteiger' },
  { href: url('/spezialisierungen/familien-kinder/'), label: 'Familien & Kinder' },
  { href: url('/spezialisierungen/immobilienbesitzer-vermieter/'), label: 'Immobilienbesitzer & Vermieter' },
  { href: url('/spezialisierungen/angestellte-gutverdiener/'), label: 'Angestellte & Gutverdiener' },
];

const gewerbeSpecialLinks = [
  { href: url('/spezialisierungen/selbstaendige-freiberufler/'), label: 'Selbständige & Freiberufler' },
  { href: url('/spezialisierungen/handwerk-baubetriebe/'), label: 'Handwerk & Baubetriebe' },
  { href: url('/spezialisierungen/gastronomie-hotellerie/'), label: 'Gastronomie & Hotellerie' },
  { href: url('/spezialisierungen/heilberufe-praxen/'), label: 'Heilberufe & Praxen' },
  { href: url('/spezialisierungen/it-medien-kreativwirtschaft/'), label: 'IT, Medien & Kreative' },
  { href: url('/spezialisierungen/produktion-industrie/'), label: 'Produktion & Industrie' },
  { href: url('/spezialisierungen/handel-transport-logistik/'), label: 'Handel & Logistik' },
  { href: url('/spezialisierungen/vereine-ehrenamt/'), label: 'Vereine & Ehrenamt' },
  { href: url('/spezialisierungen/soziale-einrichtungen-pflege/'), label: 'Soziale Einrichtungen & Pflege' },
];
---

<footer class="bg-navy-950 text-navy-300 border-t border-navy-800/50" role="contentinfo">
  <!-- Brand bar -->
  <div class="border-b border-navy-800/30">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shrink-0">
            <span class="text-navy-950 font-display font-900 text-xl leading-none">N</span>
          </div>
          <div>
            <span class="text-white font-display font-800 text-lg">Nurbanum</span>
            <span class="block text-navy-400 text-xs -mt-0.5">Unabhängige Versicherungsberatung in Zirndorf bei Nürnberg</span>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
          <a href="tel:+4917384444426" class="flex items-center gap-2 text-navy-300 hover:text-amber-400 transition-colors no-underline">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            0173 8444 4426
          </a>
          <a href="mailto:thorsten.schreier@nurbanum.de" class="flex items-center gap-2 text-navy-300 hover:text-amber-400 transition-colors no-underline">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            thorsten.schreier@nurbanum.de
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Link grid -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 lg:gap-6">
      <!-- Privatversicherungen -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Privatversicherungen</h3>
        <ul class="space-y-2">
          {privatLinks.map((link) => (
            <li>
              <a href={link.href} class={`text-sm transition-colors no-underline ${isActive(link.href) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>{link.label}</a>
            </li>
          ))}
          <li>
            <a href={url('/versicherungen/#privat')} class="text-sm text-amber-500 hover:text-amber-400 transition-colors no-underline font-medium">Alle ansehen →</a>
          </li>
        </ul>
      </div>

      <!-- Gewerbeversicherungen -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Gewerbeversicherungen</h3>
        <ul class="space-y-2">
          {gewerbeLinks.map((link) => (
            <li>
              <a href={link.href} class={`text-sm transition-colors no-underline ${isActive(link.href) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>{link.label}</a>
            </li>
          ))}
          <li>
            <a href={url('/versicherungen/#gewerbe')} class="text-sm text-amber-500 hover:text-amber-400 transition-colors no-underline font-medium">Alle ansehen →</a>
          </li>
        </ul>
      </div>

      <!-- Spezialisierungen Privat -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Spezialisierungen Privat</h3>
        <ul class="space-y-2">
          {privatSpecialLinks.map((link) => (
            <li>
              <a href={link.href} class={`text-sm transition-colors no-underline ${isActive(link.href) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>{link.label}</a>
            </li>
          ))}
          <li>
            <a href={url('/spezialisierungen/#privat')} class="text-sm text-amber-500 hover:text-amber-400 transition-colors no-underline font-medium">Alle ansehen →</a>
          </li>
        </ul>
      </div>

      <!-- Spezialisierungen Gewerbe -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Spezialisierungen Gewerbe</h3>
        <ul class="space-y-2">
          {gewerbeSpecialLinks.map((link) => (
            <li>
              <a href={link.href} class={`text-sm transition-colors no-underline ${isActive(link.href) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>{link.label}</a>
            </li>
          ))}
          <li>
            <a href={url('/spezialisierungen/#gewerbe')} class="text-sm text-amber-500 hover:text-amber-400 transition-colors no-underline font-medium">Alle ansehen →</a>
          </li>
        </ul>
      </div>

      <!-- Informationen + Rechtliches -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Informationen</h3>
        <ul class="space-y-2">
          <li><a href={url('/ratgeber/')} class={`text-sm transition-colors no-underline ${isActive(url('/ratgeber/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Ratgeber & Tipps</a></li>
          <li><a href={url('/faq/')} class={`text-sm transition-colors no-underline ${isActive(url('/faq/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Häufige Fragen</a></li>
          <li><a href={url('/glossar/')} class={`text-sm transition-colors no-underline ${isActive(url('/glossar/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Versicherungs-Glossar</a></li>
          <li><a href={url('/ueber-uns/')} class={`text-sm transition-colors no-underline ${isActive(url('/ueber-uns/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Über uns</a></li>
        </ul>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mt-6 mb-4">Rechtliches</h3>
        <ul class="space-y-2">
          <li><a href={url('/impressum/')} class={`text-sm transition-colors no-underline ${isActive(url('/impressum/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Impressum</a></li>
          <li><a href={url('/datenschutz/')} class={`text-sm transition-colors no-underline ${isActive(url('/datenschutz/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Datenschutzerklärung</a></li>
          <li><a href={url('/erstinformation/')} class={`text-sm transition-colors no-underline ${isActive(url('/erstinformation/')) ? 'text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>Erstinformation</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-navy-800/30">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-navy-400">
      <span>&copy; {currentYear} Nurbanum Versicherungsmakler — Thorsten Schreier. Alle Rechte vorbehalten.</span>
      <span>IHK-registrierter Versicherungsmakler nach §34d GewO</span>
    </div>
  </div>
</footer>
