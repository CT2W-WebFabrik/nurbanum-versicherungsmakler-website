---
import { url } from '../../utils/paths';

const currentPath = Astro.url.pathname;

const navItems = [
  { href: url('/'), label: 'Startseite' },
  { href: url('/versicherungen/'), label: 'Versicherungen', children: [
    { label: 'Für Privatpersonen', section: true },
    { href: url('/versicherungen/haftpflicht/'), label: 'Privathaftpflichtversicherung' },
    { href: url('/versicherungen/berufsunfaehigkeit/'), label: 'Berufsunfähigkeitsversicherung' },
    { href: url('/versicherungen/kfz/'), label: 'Kfz-Versicherung' },
    { href: url('/versicherungen/hausrat/'), label: 'Hausratversicherung' },
    { href: url('/versicherungen/wohngebaeude/'), label: 'Wohngebäudeversicherung' },
    { href: url('/versicherungen/#privat'), label: 'Alle ansehen →' },
    { label: 'Für Unternehmen', section: true },
    { href: url('/versicherungen/betriebshaftpflicht/'), label: 'Betriebshaftpflichtversicherung' },
    { href: url('/versicherungen/berufshaftpflicht/'), label: 'Berufshaftpflichtversicherung' },
    { href: url('/versicherungen/dno-versicherung/'), label: 'D&O-Versicherung' },
    { href: url('/versicherungen/cyber/'), label: 'Cyber-Versicherung' },
    { href: url('/versicherungen/#gewerbe'), label: 'Alle ansehen →' },
  ]},
  { href: url('/spezialisierungen/'), label: 'Spezialisierungen', children: [
    { label: 'Für Privatpersonen', section: true },
    { href: url('/spezialisierungen/berufseinsteiger-junge-erwachsene/'), label: 'Berufseinsteiger & junge Erwachsene' },
    { href: url('/spezialisierungen/familien-kinder/'), label: 'Familien & Kinder' },
    { href: url('/spezialisierungen/immobilienbesitzer-vermieter/'), label: 'Immobilienbesitzer & Vermieter' },
    { href: url('/spezialisierungen/angestellte-gutverdiener/'), label: 'Angestellte & Gutverdiener' },
    { href: url('/spezialisierungen/#privat'), label: 'Alle ansehen →' },
    { label: 'Für Unternehmen', section: true },
    { href: url('/spezialisierungen/selbstaendige-freiberufler/'), label: 'Selbständige & Freiberufler' },
    { href: url('/spezialisierungen/handwerk-baubetriebe/'), label: 'Handwerk & Baubetriebe' },
    { href: url('/spezialisierungen/heilberufe-praxen/'), label: 'Heilberufe & Praxen' },
    { href: url('/spezialisierungen/soziale-einrichtungen-pflege/'), label: 'Soziale Einrichtungen & Pflege' },
    { href: url('/spezialisierungen/#gewerbe'), label: 'Alle ansehen →' },
  ]},
  { href: url('/ratgeber/'), label: 'Ratgeber', children: [
    { label: 'Für Privatpersonen', section: true },
    { href: url('/ratgeber/welche-versicherungen-brauche-ich/'), label: 'Welche Versicherungen brauche ich?' },
    { href: url('/ratgeber/familien-versicherungen/'), label: 'Versicherungen für Familien' },
    { href: url('/ratgeber/berufseinsteiger-versicherungen/'), label: 'Versicherungen für Berufseinsteiger' },
    { href: url('/ratgeber/immobilienkauf-versicherungen/'), label: 'Versicherungen beim Immobilienkauf' },
    { href: url('/ratgeber/#privat'), label: 'Alle ansehen →' },
    { label: 'Für Unternehmen', section: true },
    { href: url('/ratgeber/gewerbeversicherungen-ueberblick/'), label: 'Gewerbeversicherungen im Überblick' },
    { href: url('/ratgeber/selbstaendige-versicherungen/'), label: 'Versicherungen für Selbständige' },
    { href: url('/ratgeber/cyber-angriff-richtig-reagieren/'), label: 'Cyber-Angriff: So reagieren Sie' },
    { href: url('/ratgeber/geschaeftsfuehrer-haftung/'), label: 'Geschäftsführerhaftung' },
    { href: url('/ratgeber/#gewerbe'), label: 'Alle ansehen →' },
  ]},
  { href: url('/ueber-uns/'), label: 'Über uns' },
  { href: url('/kontakt/'), label: 'Kontakt' },
];

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function isActive(href: string): boolean {
  const home = basePath + '/';
  if (href === home || href === basePath) return currentPath === home || currentPath === basePath;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-navy-950/95 backdrop-blur-md border-b border-navy-800/50">
  <!-- Top bar -->
  <div class="hidden sm:block bg-navy-900 border-b border-navy-800/30">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-9 text-sm">
      <span class="text-navy-300">Unabhängiger Versicherungsmakler in Zirndorf bei Nürnberg</span>
      <div class="flex items-center gap-5">
        <a href="tel:+4917384444426" class="text-navy-200 hover:text-amber-400 transition-colors flex items-center gap-1.5 no-underline">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          0173 8444 4426
        </a>
        <a href="https://wa.me/4917384444426" target="_blank" rel="noopener noreferrer" class="text-navy-200 hover:text-green-400 transition-colors flex items-center gap-1.5 no-underline">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp<span class="sr-only"> (öffnet in neuem Tab)</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main navigation -->
  <nav aria-label="Hauptnavigation" class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={url('/')} class="flex items-center gap-3 no-underline group" aria-label="Nurbanum Versicherungsmakler — Startseite">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/20" aria-hidden="true">
          <span class="text-navy-950 font-display font-900 text-xl leading-none">N</span>
        </div>
        <div>
          <span class="text-white font-display font-800 text-lg tracking-tight group-hover:text-amber-300 transition-colors">Nurbanum</span>
          <span class="hidden lg:block text-navy-300 text-xs -mt-0.5">Versicherungsmakler</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class={`px-3 py-2 text-sm font-medium rounded-md transition-all no-underline ${
                isActive(item.href)
                  ? 'text-amber-400 bg-navy-800/50'
                  : 'text-navy-200 hover:text-white hover:bg-navy-800/30'
              }`}
              {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
            >
              {item.label}
              {item.children && (
                <svg class="inline-block w-3 h-3 ml-1 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              )}
            </a>
            {item.children && (
              <div class="absolute top-full left-0 mt-1 w-72 bg-navy-900 rounded-lg shadow-xl border border-navy-700/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0" role="menu">
                <div class="py-2">
                  {item.children.map((child) => (
                    child.section
                      ? <p class="px-4 pt-3 pb-1 text-xs font-bold text-navy-400 uppercase tracking-wider first:pt-1">{child.label}</p>
                      : <a href={child.href} class={`block px-4 py-2.5 text-sm transition-colors no-underline ${child.label.includes('→') ? 'text-amber-500 hover:text-amber-400 font-medium' : 'text-navy-200 hover:text-amber-400 hover:bg-navy-800/50'}`} role="menuitem">
                          {child.label}
                        </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a href={url('/kontakt/')} class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-amber-500 hover:bg-amber-400 text-navy-950 text-sm font-bold rounded-lg transition-all shadow-lg shadow-amber-500/20 hover:shadow-amber-400/30 no-underline">
          Jetzt beraten lassen
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden p-2.5 text-navy-200 hover:text-white rounded-md hover:bg-navy-800/30 transition-colors"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="lg:hidden hidden border-t border-navy-800/50" aria-label="Mobile Navigation">
    <div class="px-4 py-4 space-y-1 max-h-[calc(100vh-8rem)] overflow-y-auto">
      {navItems.map((item) => (
        <>
          <a
            href={item.href}
            class={`block px-3 py-3 text-sm font-medium rounded-md transition-colors no-underline ${
              isActive(item.href)
                ? 'text-amber-400 bg-navy-800/50'
                : 'text-navy-200 hover:text-white hover:bg-navy-800/30'
            }`}
            {...(isActive(item.href) ? { 'aria-current': 'page' } : {})}
          >
            {item.label}
          </a>
          {item.children?.map((child) => (
            child.section
              ? <p class="pl-8 pr-3 pt-3 pb-1 text-xs font-bold text-navy-400 uppercase tracking-wider">{child.label}</p>
              : <a href={child.href} class={`block pl-8 pr-3 py-2.5 text-sm transition-colors no-underline ${child.label.includes('→') ? 'text-amber-500 hover:text-amber-400 font-medium' : 'text-navy-300 hover:text-amber-400'}`}>
                  {child.label}
                </a>
          ))}
        </>
      ))}
      <div class="pt-3 mt-2 border-t border-navy-800/50">
        <a href="tel:+4917384444426" class="flex items-center gap-2 px-3 py-3 text-sm text-navy-200 hover:text-amber-400 no-underline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          0173 8444 4426
        </a>
        <a href={url('/kontakt/')} class="block mt-2 text-center px-4 py-3 bg-amber-500 hover:bg-amber-400 text-navy-950 text-sm font-bold rounded-lg no-underline">
          Jetzt beraten lassen
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Menü öffnen' : 'Menü schließen');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Menü öffnen');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.focus();
    }
  });
</script>
