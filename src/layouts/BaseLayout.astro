---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/interactive/WhatsAppButton.astro';
import ScrollToTop from '../components/interactive/ScrollToTop.astro';
import { url } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
}

const {
  title = 'Nurbanum Versicherungsmakler — Altersvorsorge & Versicherungen in Zirndorf',
  description = 'Experte für Altersvorsorge & Ruhestandsplanung in Zirndorf. Unabhängige Beratung — persönlich, transparent, kompetent.',
  ogImage = '/images/og-default.png',
  ogType = 'website',
  noIndex = false,
} = Astro.props;

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalUrl = new URL(pathname, Astro.site);
const ogImageUrl = new URL(url(ogImage), Astro.site);
const siteUrl = 'https://nurbanum.de';
---

<!doctype html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Nurbanum Versicherungsmakler" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="icon" type="image/x-icon" href={url('/favicon.ico')} />
    <link rel="apple-touch-icon" href={url('/favicon.ico')} />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#0a0f1e" />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "@id": `${siteUrl}/#organization`,
      "name": "Nurbanum Versicherungsmakler",
      "alternateName": "Nurbanum",
      "description": "Unabhängiger Versicherungsmakler in Zirndorf bei Nürnberg. Spezialisiert auf Altersvorsorge, betriebliche Altersversorgung und Ruhestandsplanung.",
      "url": siteUrl,
      "telephone": "+4917384444426",
      "email": "thorsten.schreier@nurbanum.de",
      "image": new URL(url('/images/og-default.png'), Astro.site).toString(),
      "logo": new URL(url('/images/og-default.png'), Astro.site).toString(),
      "founder": { "@id": `${siteUrl}/#person-thorsten-schreier` },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Hans-Sachs-Straße 2",
        "addressLocality": "Zirndorf",
        "postalCode": "90513",
        "addressRegion": "Bayern",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 49.4403,
        "longitude": 10.9553
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
        "geoRadius": "50000"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "18:00"
      },
      "sameAs": ["https://www.vermittlerregister.info/recherche"]
    })} />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "name": "Nurbanum Versicherungsmakler",
      "url": siteUrl,
      "publisher": { "@id": `${siteUrl}/#organization` },
      "inLanguage": "de-DE"
    })} />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50">
    <!-- Skip to main content (accessibility) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-amber-500 focus:text-navy-950 focus:font-bold focus:rounded-lg focus:shadow-lg focus:outline-none">
      Zum Hauptinhalt springen
    </a>

    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
    <ScrollToTop />

    <script>
      document.querySelectorAll('.prose table').forEach((table) => {
        if (table.parentElement?.classList.contains('table-wrapper')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-wrapper';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });

      // Auto-generate TOC for pages that don't have a server-rendered one
      document.querySelectorAll('.prose').forEach((prose) => {
        if (prose.querySelector('.toc')) return;
        const headings = prose.querySelectorAll('h2, h3');
        if (headings.length < 3) return;
        headings.forEach((h) => {
          if (!h.id) h.id = h.textContent!.trim().toLowerCase().replace(/[^a-zäöüß0-9]+/g, '-').replace(/^-|-$/g, '');
        });
        const items = Array.from(headings)
          .filter(h => !['Weiterlesen', 'Quellen'].includes(h.textContent!.trim()))
          .map(h => `<li class="${h.tagName === 'H3' ? 'ml-4' : ''}"><a href="#${h.id}" class="block py-0.5 text-slate-600 hover:text-amber-700 transition-colors no-underline ${h.tagName === 'H2' ? 'font-medium text-navy-800' : ''}">${h.textContent!.trim()}</a></li>`)
          .join('');
        if (!items) return;
        const nav = document.createElement('nav');
        nav.className = 'toc not-prose mb-10 rounded-xl border border-slate-200 bg-slate-50/80 p-5 sm:p-6';
        nav.setAttribute('aria-label', 'Inhaltsverzeichnis');
        nav.innerHTML = `<p class="text-sm font-bold text-navy-900 uppercase tracking-wide mb-3">Inhalt</p><ol class="space-y-1.5 text-sm">${items}</ol>`;
        const first = prose.querySelector('h2');
        if (first) prose.insertBefore(nav, first);
      });
    </script>
  </body>
</html>
