---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { url } from '../utils/paths';

interface Props {
  title: string;
  description?: string;
  publishDate?: Date;
  updatedDate?: Date;
  category?: string;
  readingTime?: string;
  breadcrumbs?: { label: string; href: string }[];
  faqSchema?: object | null;
}

const { title, description, publishDate, updatedDate, category, readingTime, breadcrumbs, faqSchema } = Astro.props;
const formattedDate = publishDate?.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdate = updatedDate?.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });

// Auto-generate reading time from slot content length if not provided
const estimatedReadingTime = readingTime || undefined;

const breadcrumbItems = breadcrumbs || [];
---

<BaseLayout title={`${title} — Nurbanum Versicherungsmakler`} description={description}>
  <article class="bg-pattern">
    <div class="max-w-3xl lg:max-w-4xl xl:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-24">

      {breadcrumbItems.length > 0 && (
        <div class="animate-fade-in">
          <Breadcrumb items={breadcrumbItems} current={title} />
        </div>
      )}

      <header class="mb-12 animate-fade-in">
        {category && (
          <span class="inline-block text-sm font-medium text-amber-700 bg-amber-100 px-3 py-1 rounded-full mb-4">
            {category}
          </span>
        )}
        <h1 class="font-display mb-4">{title}</h1>
        <div class="flex flex-wrap gap-4 text-sm text-slate-500">
          {formattedDate && (
            <time datetime={publishDate?.toISOString()}>
              {formattedDate}
            </time>
          )}
          {formattedUpdate && (
            <span>Aktualisiert: {formattedUpdate}</span>
          )}
          {estimatedReadingTime && <span>{estimatedReadingTime} Lesezeit</span>}
          <span>Von Thorsten Schreier</span>
        </div>
      </header>

      <div class="prose prose-lg max-w-none
        prose-headings:text-navy-950
        prose-a:text-navy-600 prose-a:decoration-amber-400
        prose-strong:text-navy-800
        prose-li:marker:text-amber-500
        animate-slide-up" style="animation-delay: 0.15s">
        <slot />
      </div>

      <footer class="mt-16 pt-8 border-t border-slate-200">
        <div class="flex items-center gap-4">
          <img src={url('/images/thorsten-schreier.jpg')} alt="Thorsten Schreier" class="w-14 h-14 rounded-full object-cover shrink-0" width="56" height="56" loading="lazy" />
          <div>
            <p class="font-medium text-navy-900">Thorsten Schreier</p>
            <p class="text-sm text-slate-500">Versicherungsmakler — Nurbanum</p>
          </div>
        </div>
      </footer>
    </div>
  </article>

  {/* Article structured data */}
  {publishDate && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "image": new URL(url('/images/og-default.png'), Astro.site).toString(),
      "author": {
        "@id": "https://nurbanum.de/#person-thorsten-schreier",
        "@type": "Person",
        "name": "Thorsten Schreier",
        "jobTitle": "Versicherungsmakler"
      },
      "publisher": { "@id": "https://nurbanum.de/#organization" },
      "datePublished": publishDate.toISOString(),
      "dateModified": (updatedDate ?? publishDate).toISOString(),
      "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href }
    })} />
  )}

  {/* FAQPage structured data — only injected when FAQ content exists */}
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

</BaseLayout>
