---
import { url } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const latestRatgeber = (await getCollection('ratgeber'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const insuranceTypes = [
  { title: 'Haftpflichtversicherung', href: '/versicherungen/haftpflicht/', icon: 'shield' },
  { title: 'Berufsunfähigkeit', href: '/versicherungen/berufsunfaehigkeit/', icon: 'briefcase' },
  { title: 'KFZ-Versicherung', href: '/versicherungen/kfz/', icon: 'car' },
  { title: 'Hausratversicherung', href: '/versicherungen/hausrat/', icon: 'home' },
  { title: 'Wohngebäudeversicherung', href: '/versicherungen/wohngebaeude/', icon: 'building' },
  { title: 'Rechtsschutzversicherung', href: '/versicherungen/rechtsschutz/', icon: 'scale' },
  { title: 'Risikolebensversicherung', href: '/versicherungen/risikoleben/', icon: 'heart' },
  { title: 'Krankenversicherung', href: '/versicherungen/krankenversicherung/', icon: 'medical' },
  { title: 'Unfallversicherung', href: '/versicherungen/unfallversicherung/', icon: 'alert' },
  { title: 'Pflegeversicherung', href: '/versicherungen/pflegeversicherung/', icon: 'care' },
  { title: 'Gewerbeversicherung', href: '/versicherungen/gewerbe/', icon: 'office' },
  { title: 'Cyberversicherung', href: '/versicherungen/cyber/', icon: 'cyber' },
];
---

<BaseLayout
  title="Nurbanum Versicherungsmakler — Ihr Experte für Altersvorsorge in Nürnberg"
  description="Experte für Altersvorsorge & Ruhestandsplanung in Zirndorf. Unabhängige Versicherungsberatung — persönlich, transparent, kompetent."
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/95 via-navy-900/85 to-navy-800/75"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_30%,rgba(245,158,11,0.12)_0%,transparent_60%)]"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-36">
      <div class="max-w-3xl">
        <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-6 animate-fade-in">
          Unabhängiger Versicherungsmakler in Zirndorf
        </p>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-900 text-white mb-6 animate-slide-up leading-[1.08]">
          Ihr Experte für
          <span class="text-amber-400"> Altersvorsorge &</span>
          Ruhestandsplanung
        </h1>
        <p class="text-lg sm:text-xl text-navy-200 max-w-2xl mb-10 animate-slide-up leading-relaxed" style="animation-delay: 0.15s;">
          Reicht Ihre Rente? Ich analysiere Ihre Situation, berechne die Versorgungslücke und entwickle einen konkreten Plan — unabhängig, persönlich und transparent.
        </p>
        <div class="flex flex-wrap gap-4 animate-slide-up" style="animation-delay: 0.3s;">
          <a href={url('/kontakt/')} class="inline-flex items-center gap-2 px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-bold text-lg rounded-xl transition-all shadow-lg shadow-amber-500/25 hover:shadow-amber-400/35 no-underline">
            Kostenlose Erstberatung
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="tel:+4917384444426" class="inline-flex items-center gap-2 px-8 py-4 border-2 border-navy-500 text-navy-200 hover:text-white hover:border-navy-300 font-semibold rounded-xl transition-all no-underline">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            0173 8444 4426
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST BAR ═══ -->
  <section class="bg-navy-950 border-t border-navy-800">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-sm">
        <span class="flex items-center gap-2 text-navy-300">
          <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          IHK-registriert
        </span>
        <span class="flex items-center gap-2 text-navy-300">
          <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          DVA-zertifiziert
        </span>
        <span class="flex items-center gap-2 text-navy-300">
          <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          100% unabhängig
        </span>
        <span class="flex items-center gap-2 text-navy-300">
          <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Region Nürnberg
        </span>
      </div>
    </div>
  </section>

  <!-- ═══ SPEZIALISIERUNGEN ═══ -->
  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-4">Schwerpunkte</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950 mb-6">Meine Spezialisierungen</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Altersvorsorge und Ruhestandsplanung sind mein Kerngebiet. Hier berate ich Sie besonders tiefgehend.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
        <!-- bAV -->
        <a href={url('/spezialisierungen/betriebliche-altersversorgung/')} class="group bg-white rounded-2xl border border-slate-100 p-8 shadow-sm hover:shadow-xl hover:border-amber-300 transition-all no-underline">
          <div class="w-14 h-14 rounded-xl bg-navy-950 flex items-center justify-center mb-6 group-hover:bg-amber-500 transition-colors">
            <svg class="w-7 h-7 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-950 mb-3 group-hover:text-amber-700 transition-colors">Betriebliche Altersversorgung</h3>
          <p class="text-base text-slate-600 leading-relaxed mb-4">Durchführungswege, Arbeitgeberzuschuss, Entgeltumwandlung — für Unternehmen und Arbeitnehmer.</p>
          <span class="text-sm font-semibold text-amber-600 group-hover:text-amber-700 inline-flex items-center gap-1">
            Mehr erfahren <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </span>
        </a>

        <!-- Private Altersvorsorge -->
        <a href={url('/spezialisierungen/altersvorsorge/')} class="group bg-white rounded-2xl border border-slate-100 p-8 shadow-sm hover:shadow-xl hover:border-amber-300 transition-all no-underline">
          <div class="w-14 h-14 rounded-xl bg-navy-950 flex items-center justify-center mb-6 group-hover:bg-amber-500 transition-colors">
            <svg class="w-7 h-7 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-950 mb-3 group-hover:text-amber-700 transition-colors">Private Altersvorsorge</h3>
          <p class="text-base text-slate-600 leading-relaxed mb-4">Riester, Rürup, ETF-Rente oder private Rentenversicherung — die optimale Strategie für Ihre Situation.</p>
          <span class="text-sm font-semibold text-amber-600 group-hover:text-amber-700 inline-flex items-center gap-1">
            Mehr erfahren <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </span>
        </a>

        <!-- Ruhestandsplanung -->
        <a href={url('/spezialisierungen/ruhestandsplanung/')} class="group bg-white rounded-2xl border border-slate-100 p-8 shadow-sm hover:shadow-xl hover:border-amber-300 transition-all no-underline">
          <div class="w-14 h-14 rounded-xl bg-navy-950 flex items-center justify-center mb-6 group-hover:bg-amber-500 transition-colors">
            <svg class="w-7 h-7 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-navy-950 mb-3 group-hover:text-amber-700 transition-colors">Ruhestandsplanung</h3>
          <p class="text-base text-slate-600 leading-relaxed mb-4">Versorgungslücke berechnen, Renteninformation verstehen, konkrete Schritte bis zum Ruhestand planen.</p>
          <span class="text-sm font-semibold text-amber-600 group-hover:text-amber-700 inline-flex items-center gap-1">
            Mehr erfahren <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ALLE VERSICHERUNGEN ═══ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-4">Versicherungen</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950 mb-6">Rundum gut versichert</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Von Haftpflicht bis Cyber — ich finde für jede Lebenslage den passenden Schutz.</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {insuranceTypes.map(item => (
          <a href={url(item.href)} class="group flex items-center gap-3 bg-slate-50 hover:bg-amber-50 rounded-xl p-4 border border-slate-100 hover:border-amber-200 transition-all no-underline">
            <div class="w-10 h-10 rounded-lg bg-navy-950 flex items-center justify-center shrink-0 group-hover:bg-amber-500 transition-colors">
              <svg class="w-5 h-5 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <span class="text-sm font-medium text-navy-800 group-hover:text-amber-800 transition-colors">{item.title}</span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href={url('/versicherungen/')} class="inline-flex items-center gap-2 text-sm font-semibold text-navy-600 hover:text-amber-700 transition-colors no-underline">
          Alle Versicherungen anzeigen
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ WARUM NURBANUM ═══ -->
  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-4">Warum Nurbanum</p>
          <h2 class="text-2xl sm:text-3xl font-800 text-navy-950 mb-6">Weil es nur um Sie geht</h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            „Nurbanum" steht für genau das: Ihre Versicherungen und Ihre Vorsorge sollten nur um Sie gehen. Nicht um Provisionen, nicht um Verkaufsziele.
          </p>
          <a href={url('/ueber-uns/')} class="inline-flex items-center gap-2 text-sm font-semibold text-amber-600 hover:text-amber-700 no-underline transition-colors">
            Mehr über mich erfahren
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-2xl border border-slate-100 p-7 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
            </div>
            <h3 class="text-lg font-bold text-navy-950 mb-2">Unabhängig</h3>
            <p class="text-base text-slate-600 leading-relaxed">Nicht an ein Unternehmen gebunden — ich vergleiche für Sie den gesamten Markt.</p>
          </div>

          <div class="bg-white rounded-2xl border border-slate-100 p-7 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
            </div>
            <h3 class="text-lg font-bold text-navy-950 mb-2">DVA-zertifiziert</h3>
            <p class="text-base text-slate-600 leading-relaxed">Ausbildung an der Deutschen Versicherungsakademie. Regelmäßige Weiterbildung.</p>
          </div>

          <div class="bg-white rounded-2xl border border-slate-100 p-7 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            </div>
            <h3 class="text-lg font-bold text-navy-950 mb-2">Persönlich</h3>
            <p class="text-base text-slate-600 leading-relaxed">Kein Callcenter, kein Chatbot. Ich berate Sie persönlich — vor Ort oder digital.</p>
          </div>

          <div class="bg-white rounded-2xl border border-slate-100 p-7 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <h3 class="text-lg font-bold text-navy-950 mb-2">Regional</h3>
            <p class="text-base text-slate-600 leading-relaxed">Zu Hause in Zirndorf und der Metropolregion Nürnberg. Ihr Makler vor Ort.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RATGEBER TEASER ═══ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-4">Wissen</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950 mb-6">Ratgeber & Tipps</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Verständlich erklärt: So treffen Sie bessere Entscheidungen bei Versicherungen und Vorsorge.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {latestRatgeber.map(guide => (
          <a href={url(`/ratgeber/${guide.id}/`)} class="group bg-slate-50 hover:bg-amber-50 rounded-2xl border border-slate-100 hover:border-amber-200 p-7 transition-all no-underline">
            <span class="inline-block text-xs font-semibold text-amber-700 bg-amber-100 px-2.5 py-1 rounded-full mb-4">{guide.data.category}</span>
            <h3 class="text-lg font-bold text-navy-950 mb-3 group-hover:text-amber-700 transition-colors leading-snug">{guide.data.title}</h3>
            <p class="text-base text-slate-600 leading-relaxed">{guide.data.description}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href={url('/ratgeber/')} class="inline-flex items-center gap-2 text-sm font-semibold text-navy-600 hover:text-amber-700 transition-colors no-underline">
          Alle Ratgeber anzeigen
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ KUNDENSTIMMEN ═══ -->
  <section class="py-20 sm:py-28 bg-navy-950">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4">Kundenstimmen</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-white mb-6">Was meine Kunden sagen</h2>
        <p class="text-lg text-navy-300 max-w-2xl mx-auto">Echte Bewertungen folgen in Kürze. Überzeugen Sie sich selbst in einem persönlichen Gespräch.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          { text: 'Thorsten hat sich wirklich Zeit genommen, meine gesamte Absicherung zu analysieren. Endlich verstehe ich, was ich habe und was mir fehlt.', name: 'Zufriedener Kunde', location: 'Nürnberg' },
          { text: 'Die betriebliche Altersversorgung für unser Unternehmen wurde professionell aufgesetzt. Klare Empfehlung für kleine und mittelständische Betriebe.', name: 'Zufriedener Arbeitgeber', location: 'Fürth' },
          { text: 'Endlich ein Makler, der verständlich erklärt und nicht einfach nur verkaufen will. Die Ruhestandsplanung hat mir enorm geholfen.', name: 'Zufriedene Kundin', location: 'Zirndorf' },
        ].map(item => (
