---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Schutz vor Schadensersatz bei beruflichen Fehlern — für viele Berufe Pflicht.' },
  { title: 'Berufsunfähigkeitsversicherung', href: url('/versicherungen/berufsunfaehigkeit/'), description: 'Ihr wichtigstes Kapital ist Ihre Arbeitskraft. Sichern Sie Ihr Einkommen ab.' },
  { title: 'Krankenversicherung', href: url('/versicherungen/krankenversicherung/'), description: 'PKV oder freiwillig gesetzlich? Die richtige Wahl für Ihre Situation.' },
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz vor Ansprüchen Dritter aus Ihrer betrieblichen Tätigkeit.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Geschäftsführerhaftung absichern — auch für Inhaber kleiner GmbHs wichtig.' },
  { title: 'Krankentagegeldversicherung', href: url('/versicherungen/krankentagegeld/'), description: 'Einkommenssicherung bei Krankheit — kein Arbeitgeber zahlt Lohnfortzahlung.' },
];
---

<BaseLayout
  title="Versicherungen für Selbständige & Freiberufler — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Selbständige? Berufshaftpflicht, BU, Krankenversicherung, D&O — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Selbständige & Freiberufler</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Als Selbständiger tragen Sie alle Risiken selbst. Ich sorge dafür, dass die richtigen Versicherungen stehen — und keine unnötigen.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Freie Berufe & Dienstleistung', href: '/spezialisierungen/#gewerbe' }]} current="Selbständige & Freiberufler" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Besondere Risiken für Selbständige</h2>
        <p>Angestellte haben ein Sicherheitsnetz: Lohnfortzahlung im Krankheitsfall, gesetzliche Unfallversicherung am Arbeitsplatz, Arbeitgeberzuschüsse zur Sozialversicherung. Als Selbständiger oder Freiberufler entfallen diese Absicherungen. Sie müssen selbst vorsorgen — und das richtig.</p>
        <p>Die größten Risiken: Eine längere Krankheit ohne Einkommensersatz. Ein beruflicher Fehler, der einen Kunden teuer zu stehen kommt. Oder ein Haftungsfall, der Ihr Privatvermögen gefährdet.</p>

        <h2>Pflichtversicherungen — das müssen Sie haben</h2>
        <p>Für viele Selbständige sind bestimmte Versicherungen gesetzlich vorgeschrieben:</p>
        <ul>
          <li><strong>Berufshaftpflicht</strong> — Pflicht für Rechtsanwälte, Steuerberater, Architekten, Ärzte, Versicherungsmakler und weitere regulierte Berufe. Aber auch ohne Pflicht für jeden Dienstleister dringend empfohlen.</li>
          <li><strong>Krankenversicherung</strong> — Versicherungspflicht besteht für alle. Die Wahl zwischen PKV und freiwilliger GKV hat langfristige Konsequenzen für Beiträge und Leistungen.</li>
          <li><strong>Kfz-Haftpflicht</strong> — Für geschäftlich genutzte Fahrzeuge.</li>
        </ul>

        <h2>Dringend empfohlen — Existenzschutz</h2>
        <ul>
          <li><strong>Berufsunfähigkeitsversicherung</strong> — Ihr Einkommen ist Ihr wichtigstes Kapital. Eine BU sichert es ab, wenn Sie aus gesundheitlichen Gründen nicht mehr arbeiten können. Für Selbständige gibt es keine Erwerbsminderungsrente.</li>
          <li><strong>Krankentagegeld</strong> — Kein Arbeitgeber zahlt Ihnen Lohnfortzahlung. Ab dem ersten Krankheitstag fehlt Ihnen Einkommen. Das Krankentagegeld schließt diese Lücke — wählen Sie eine kurze Karenzzeit.</li>
          <li><strong>Betriebshaftpflicht</strong> — Schützt Sie, wenn Sie durch Ihre Tätigkeit Personen- oder Sachschäden bei Dritten verursachen.</li>
        </ul>

        <h2>Für GmbH-Geschäftsführer</h2>
        <p>Als Geschäftsführer einer GmbH haften Sie persönlich und unbeschränkt mit Ihrem Privatvermögen für Pflichtverletzungen (§43 GmbHG). Eine D&O-Versicherung (Managerhaftpflicht) schützt Sie vor den finanziellen Folgen — auch und gerade bei kleinen Unternehmen, wo Geschäftsführer und Gesellschafter oft dieselbe Person sind.</p>

        <h2>Altersvorsorge nicht vergessen</h2>
        <p>Selbständige sind in der Regel nicht gesetzlich rentenversicherungspflichtig. Das bedeutet mehr Freiheit, aber auch mehr Verantwortung. Ohne aktive Vorsorge droht Altersarmut. Die Rürup-Rente (Basisrente) bietet Selbständigen steuerliche Vorteile vergleichbar mit der gesetzlichen Rente — bei voller Flexibilität.</p>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Selbständige</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Gründercheck oder Bestandsaufnahme</h3>
        <p class="text-slate-300 mb-6">Ob Neugründung oder seit Jahren selbständig — ich prüfe Ihren Versicherungsschutz und schließe Lücken. Kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
