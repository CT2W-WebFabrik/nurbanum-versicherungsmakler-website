---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz bei Personen- und Sachschäden durch landwirtschaftliche Tätigkeit.' },
  { title: 'Maschinenversicherung', href: url('/versicherungen/maschinenversicherung/'), description: 'Traktoren, Mähdrescher, Erntemaschinen — Schutz bei Ausfall und Beschädigung.' },
  { title: 'Betriebsgebäudeversicherung', href: url('/versicherungen/betriebsgebaeudeversicherung/'), description: 'Ställe, Scheunen, Lagerhallen — Schutz vor Feuer, Sturm und Elementarschäden.' },
  { title: 'Kfz-Flottenversicherung', href: url('/versicherungen/kfz-flotten/'), description: 'Landwirtschaftliche Fahrzeuge und Anhänger im Fuhrpark versichern.' },
  { title: 'Unfallversicherung', href: url('/versicherungen/unfallversicherung/'), description: 'Landwirtschaft gehört zu den unfallträchtigsten Branchen — privater Zusatzschutz wichtig.' },
];
---

<BaseLayout
  title="Land- & Forstwirtschaft absichern — Nurbanum Versicherungsmakler"
  description="Versicherungen für Landwirte und Forstbetriebe: Betriebshaftpflicht, Maschinen, Gebäude, Ernteschäden — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Land- & Forstwirtschaft</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Wetterrisiken, teure Maschinen, hohe Unfallgefahr — landwirtschaftliche Betriebe brauchen maßgeschneiderten Versicherungsschutz.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Handwerk, Handel & Industrie', href: '/spezialisierungen/#gewerbe-handwerk-handel-industrie' }]} current="Land- & Forstwirtschaft" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Besondere Risiken in der Landwirtschaft</h2>
        <p>Landwirtschaftliche Betriebe verbinden Wohnen und Arbeiten, besitzen teure Maschinen, sind vom Wetter abhängig und arbeiten mit Tieren. Diese Kombination erfordert einen Versicherungsschutz, der über das übliche Gewerbepaket hinausgeht.</p>
        <h2>Die wichtigsten Bausteine</h2>
        <ul>
          <li><strong>Betriebshaftpflicht</strong> — Inklusive landwirtschaftlicher Sonderrisiken: Tierhaltung, Gülleausbringung, Lohnarbeit für andere Landwirte, Hofverkauf.</li>
          <li><strong>Gebäudeversicherung</strong> — Ställe, Scheunen und Lagerhallen mit Elementarschutz. Feuer in landwirtschaftlichen Gebäuden ist ein häufiger Großschaden.</li>
          <li><strong>Maschinenversicherung</strong> — Moderne Landmaschinen kosten sechsstellige Beträge. Schutz bei Maschinenbruch, Kurzschluss und Bedienungsfehlern.</li>
          <li><strong>Ernte-/Hagelversicherung</strong> — Schutz der Ernte vor Hagel, Sturm, Starkregen und Frost. Unverzichtbar für pflanzenbauliche Betriebe.</li>
        </ul>
        <h2>Unfallschutz für Landwirte</h2>
        <p>Die Landwirtschaft gehört zu den unfallträchtigsten Branchen. Die landwirtschaftliche Berufsgenossenschaft (SVLFG) bietet einen Grundschutz, aber die Leistungen sind begrenzt. Eine private Unfallversicherung ergänzt den Schutz erheblich.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Landwirte</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Hofcheck: Ist Ihr Betrieb richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihre landwirtschaftlichen Versicherungen und zeige Optimierungspotenzial — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>
</BaseLayout>
