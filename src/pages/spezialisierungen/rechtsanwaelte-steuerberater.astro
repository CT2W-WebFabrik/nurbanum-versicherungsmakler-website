---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Pflichtversicherung — Berufsordnung schreibt Mindestdeckungssummen vor.' },
  { title: 'Vermögensschadenhaftpflicht', href: url('/versicherungen/vermoegensschadenhaftpflicht/'), description: 'Schutz bei reinen Vermögensschäden durch Beratungsfehler.' },
  { title: 'Cyber-Versicherung', href: url('/versicherungen/cyber/'), description: 'Mandantendaten sind hochsensibel — Schutz bei Datenpannen und Hacking.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Persönliche Haftung der Partner und Geschäftsführer absichern.' },
  { title: 'Firmen-Rechtsschutz', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Schutz bei Honorarstreitigkeiten und arbeitsrechtlichen Konflikten.' },
];
---

<BaseLayout
  title="Rechtsanwälte & Steuerberater absichern — Nurbanum Versicherungsmakler"
  description="Pflicht-Berufshaftpflicht, Vermögensschadenhaftpflicht, Cyber — Versicherungen für Rechtsanwälte und Steuerberater."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Rechtsanwälte & Steuerberater</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Beratungsfehler können existenzbedrohend sein. Ich finde den Haftpflichtschutz, der über die Pflichtversicherung hinausgeht.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Freie Berufe & Dienstleistung', href: '/spezialisierungen/#gewerbe-freie-berufe-dienstleistung' }]} current="Rechtsanwälte & Steuerberater" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Pflicht-Berufshaftpflicht: Nur der Anfang</h2>
        <p>Rechtsanwälte und Steuerberater sind berufsrechtlich verpflichtet, eine Berufshaftpflichtversicherung abzuschließen. Die Mindestdeckungssummen (250.000 Euro für Anwälte, 250.000 Euro für Steuerberater) reichen in der Praxis oft nicht aus — ein einziger größerer Beratungsfehler kann diese Summe übersteigen.</p>
        <h2>Typische Risiken</h2>
        <ul>
          <li><strong>Fristversäumnisse</strong> — Eine verpasste Frist kann für den Mandanten irreversible Folgen haben — und Sie haften voll.</li>
          <li><strong>Fehlerhafte Steuerberatung</strong> — Steuernachzahlungen, Zinsen und Bußgelder bei fehlerhafter Steuergestaltung oder -erklärung.</li>
          <li><strong>Cyber-Angriffe</strong> — Kanzleien speichern hochsensible Mandantendaten. Ein Datenleck kann neben dem Eigenschaden auch DSGVO-Bußgelder und Reputationsverlust bedeuten.</li>
          <li><strong>Gesellschafterhaftung</strong> — Partner in einer Sozietät oder PartG haften unter Umständen persönlich. Eine D&O-Versicherung schützt das Privatvermögen.</li>
        </ul>
        <h2>Über die Pflicht hinaus</h2>
        <p>Ich prüfe Ihre bestehende Berufshaftpflicht auf Deckungslücken, empfehle angemessene Deckungssummen für Ihr Mandatsvolumen und ergänze bei Bedarf Cyber-Schutz, D&O und Kanzlei-Rechtsschutz.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Kanzleien</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Kanzlei-Check: Haftpflicht optimal aufgestellt?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihren Schutz und zeige, wo die Pflichtversicherung nicht ausreicht — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Rechtsanwälte & Steuerberater absichern",
    "description": "Pflicht-Berufshaftpflicht, Vermögensschadenhaftpflicht, Cyber — Versicherungen für Rechtsanwälte und Steuerberater.",
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
