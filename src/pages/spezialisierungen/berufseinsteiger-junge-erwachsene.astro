---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Berufsunfähigkeitsversicherung', href: url('/versicherungen/berufsunfaehigkeit/'), description: 'Je jünger, desto günstiger und einfacher der Abschluss — Ihr wichtigstes Kapital absichern.' },
  { title: 'Privathaftpflichtversicherung', href: url('/versicherungen/haftpflicht/'), description: 'Ihre erste eigene Police nach dem Auszug — existenzieller Schutz für unter 100 Euro im Jahr.' },
  { title: 'Hausratversicherung', href: url('/versicherungen/hausrat/'), description: 'Schutz für Ihre erste eigene Wohnung gegen Feuer, Einbruch und Wasserschäden.' },
  { title: 'Krankenversicherung', href: url('/versicherungen/krankenversicherung/'), description: 'PKV oder GKV? Die richtige Entscheidung am Karrierestart hat langfristige Folgen.' },
  { title: 'Zahnzusatzversicherung', href: url('/versicherungen/zahnzusatzversicherung/'), description: 'Früh abschließen: Keine Vorerkrankungen, keine Wartezeiten, niedrige Beiträge.' },
  { title: 'Private Altersvorsorge', href: url('/versicherungen/private-altersvorsorge/'), description: 'Der Zinseszins-Vorsprung: Mit 25 anfangen schlägt mit 35 anfangen deutlich.' },
];
---

<BaseLayout
  title="Versicherungen für Berufseinsteiger & junge Erwachsene — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Berufseinsteiger? BU, Haftpflicht, Zahnzusatz, Altersvorsorge — was wirklich wichtig ist und was warten kann."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Berufseinsteiger & junge Erwachsene</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Ausbildung, Studium, erster Job — am Karrierestart sind die richtigen Versicherungen günstig und die falschen teuer. Ich zeige Ihnen, was Sie wirklich brauchen.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Privatpersonen', href: '/spezialisierungen/#privat' }, { label: 'Lebensphasen', href: '/spezialisierungen/#privat-lebensphasen' }]} current="Berufseinsteiger & junge Erwachsene" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Versicherungen beim Berufsstart: Was ist wirklich wichtig?</h2>
        <p>Wenn Sie ausziehen, eine Ausbildung beginnen oder den ersten Job antreten, fallen Sie aus vielen Versicherungen Ihrer Eltern heraus: Die Familienversicherung in der GKV endet, der Familien-Haftpflichttarif greift nicht mehr, die Hausratversicherung der Eltern schützt Ihre neue Wohnung nicht. Gleichzeitig ist der Beginn des Berufslebens der beste Zeitpunkt, bestimmte Versicherungen abzuschließen — weil Sie jung, gesund und die Beiträge entsprechend niedrig sind.</p>
        <p>Die gute Nachricht: Sie brauchen am Anfang nur wenige Versicherungen. Die schlechte: Die wirklich wichtigen sollten Sie nicht aufschieben.</p>

        <h2>Berufsunfähigkeitsversicherung — je früher, desto besser</h2>
        <p>Die BU ist die wichtigste Versicherung für Berufseinsteiger. Ihr Einkommen ist Ihr größtes Kapital — über ein Berufsleben gerechnet verdienen Sie weit über eine Million Euro. Wenn Sie aus gesundheitlichen Gründen nicht mehr arbeiten können, zahlt der Staat als Berufseinsteiger praktisch nichts (die Erwerbsminderungsrente setzt 5 Jahre Beitragszahlung voraus).</p>
        <p>Der entscheidende Vorteil eines frühen Abschlusses:</p>
        <ul>
          <li><strong>Niedrigere Beiträge</strong> — Ein 25-Jähriger zahlt oft 30–50 % weniger als ein 35-Jähriger für dieselbe Leistung</li>
          <li><strong>Einfachere Gesundheitsfragen</strong> — Weniger Vorerkrankungen bedeuten weniger Ausschlüsse und Risikozuschläge</li>
          <li><strong>Nachversicherungsgarantie</strong> — Wenn Ihr Gehalt steigt, können Sie die versicherte Rente ohne erneute Gesundheitsprüfung erhöhen</li>
        </ul>

        <h2>Haftpflicht und Hausrat: Die Grundausstattung</h2>
        <p>Die <strong>Privathaftpflichtversicherung</strong> ist nach der BU die wichtigste Police. Wenn Sie jemandem einen Schaden zufügen — ein Radfahrer ausweichen muss und stürzt, Sie bei Freunden die teure Kamera vom Tisch stoßen — haften Sie mit Ihrem gesamten Vermögen. Bei Personenschäden können Forderungen in die Millionen gehen. Die Haftpflicht kostet unter 100 Euro im Jahr und schützt Ihre Existenz.</p>
        <p>Die <strong>Hausratversicherung</strong> wird sinnvoll, sobald Sie in Ihrer ersten Wohnung Werte angesammelt haben, die Sie im Schadenfall nicht aus eigener Tasche ersetzen könnten. Für ein WG-Zimmer mit IKEA-Möbeln brauchen Sie sie nicht — für eine eingerichtete Wohnung mit Elektronik schon.</p>

        <h2>Gesundheitsvorsorge früh sichern</h2>
        <ul>
          <li><strong>Zahnzusatzversicherung</strong> — Schließen Sie sie ab, bevor der Zahnarzt einen Behandlungsbedarf feststellt. Einmal diagnostiziert, wird die Vorerkrankung ausgeschlossen oder der Beitrag erhöht. In jungen Jahren ist der Tarif am günstigsten.</li>
          <li><strong>Auslandskrankenversicherung</strong> — Für Work & Travel, Erasmus-Semester oder Fernreisen unverzichtbar. Eine Jahrespolice kostet oft unter 15 Euro.</li>
          <li><strong>PKV-Option für Beamtenanwärter</strong> — Wer eine Beamtenlaufbahn einschlägt, sollte die Entscheidung PKV vs. GKV früh und gut beraten treffen. Die Beihilfe macht die PKV für Beamte oft deutlich günstiger.</li>
        </ul>

        <h2>Altersvorsorge: Der Zinseszins-Vorsprung</h2>
        <p>Rente klingt mit 25 weit weg — ist es aber nicht. Wer mit 25 Jahren 100 Euro monatlich bei 6 % Rendite anlegt, hat mit 67 rund 200.000 Euro. Wer erst mit 35 anfängt, kommt bei gleicher Sparrate nur auf knapp 100.000 Euro. Zehn Jahre machen den doppelten Unterschied.</p>
        <p>Starten Sie mit vermögenswirksamen Leistungen (VL) — viele Arbeitgeber zahlen bis zu 40 Euro monatlich, die Sie sonst verschenken. Darüber hinaus sind ETF-Sparpläne, die Riester-Zulage (bei GKV-Pflichtmitgliedern) oder eine Rürup-Rente (für Selbständige) sinnvolle Einstiegswege.</p>

        <h2>Was Sie am Anfang nicht brauchen</h2>
        <p>Nicht jede Versicherung ist beim Berufsstart sinnvoll. Kapitalbildende Lebensversicherungen, Sterbegeldversicherungen und teure Rundumschutz-Pakete sind in der Regel zu früh und zu teuer. Investieren Sie zuerst in die existenziellen Absicherungen — alles andere kann warten.</p>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Berufseinsteiger</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Berufsstart-Check: Welche Versicherungen brauchen Sie wirklich?</h3>
        <p class="text-slate-300 mb-6">Ich zeige Ihnen, welche Versicherungen jetzt wichtig sind und welche warten können — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
