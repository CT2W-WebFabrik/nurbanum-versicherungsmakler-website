---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz bei Personen- und Sachschäden auf Ihren Baustellen.' },
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Schutz bei Planungs- und Beratungsfehlern in der Projektentwicklung.' },
  { title: 'Bauleistungsversicherung', href: url('/versicherungen/bauleistungsversicherung/'), description: 'Schutz für das Bauwerk während der Bauphase — Pflicht bei Großprojekten.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Persönliche Haftung der Geschäftsführung absichern — bei Projektgesellschaften besonders wichtig.' },
  { title: 'Betriebsunterbrechungsversicherung', href: url('/versicherungen/betriebsunterbrechung/'), description: 'Umsatzschutz bei Bauverzögerungen und Projektunterbrechungen.' },
];
---

<BaseLayout
  title="Bauträger & Projektentwickler absichern — Nurbanum Versicherungsmakler"
  description="Versicherungen für Bauträger: Bauleistung, Berufshaftpflicht, D&O — Schutz für komplexe Bauprojekte."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Bauträger & Projektentwickler</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Große Projekte, große Risiken. Ich finde den Versicherungsschutz, der zu Ihrem Projektvolumen passt.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Handwerk, Handel & Industrie', href: '/spezialisierungen/#gewerbe-handwerk-handel-industrie' }]} current="Bauträger & Projektentwickler" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Komplexe Risiken in der Projektentwicklung</h2>
        <p>Bauträger und Projektentwickler tragen ein enormes finanzielles Risiko: Sie koordinieren zahlreiche Subunternehmer, haften gegenüber Käufern für Baumängel und setzen oft Millionenbeträge ein, bevor die erste Wohnung verkauft ist. Die richtige Versicherungsstrategie ist hier geschäftskritisch.</p>
        <h2>Die wichtigsten Bausteine</h2>
        <ul>
          <li><strong>Bauleistungsversicherung</strong> — Schützt das Bauwerk während der Bauphase vor unvorhergesehenen Schäden. Bei Großprojekten von Finanzierern oft gefordert.</li>
          <li><strong>Bauherrenhaftpflicht</strong> — Deckt Ihre Haftung als Bauherr gegenüber Dritten (Passanten, Nachbarn, Lieferanten).</li>
          <li><strong>Berufshaftpflicht</strong> — Schutz bei Planungs- und Beratungsfehlern. Besonders relevant, wenn Sie die Planung mitverantworten.</li>
          <li><strong>D&O-Versicherung</strong> — Bei Projektgesellschaften (Zweckgesellschaften/SPVs) haftet die Geschäftsführung persönlich für Fehlentscheidungen.</li>
        </ul>
        <h2>Subunternehmer-Management</h2>
        <p>Prüfen Sie die Versicherungsnachweise Ihrer Subunternehmer systematisch. Ihr eigener Versicherungsschutz ersetzt nicht die Absicherung der beauftragten Unternehmen — Haftungslücken in der Kette treffen am Ende Sie als Bauträger.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Bauträger</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Projekt-Check: Versicherung für Ihr Bauvorhaben</h3>
        <p class="text-slate-300 mb-6">Ich stelle ein maßgeschneidertes Versicherungspaket für Ihr Projekt zusammen — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Bauträger & Projektentwickler absichern",
    "description": "Versicherungen für Bauträger: Bauleistung, Berufshaftpflicht, D&O — Schutz für komplexe Bauprojekte.",
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
