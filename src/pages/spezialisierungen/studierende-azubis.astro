---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Privathaftpflichtversicherung', href: url('/versicherungen/haftpflicht/'), description: 'Die wichtigste Versicherung — prüfen Sie, ob Sie noch über die Eltern versichert sind.' },
  { title: 'Berufsunfähigkeitsversicherung', href: url('/versicherungen/berufsunfaehigkeit/'), description: 'Je jünger der Abschluss, desto günstiger der Beitrag — ein Leben lang.' },
  { title: 'Auslandskrankenversicherung', href: url('/versicherungen/auslandskrankenversicherung/'), description: 'Für Auslandssemester, Work & Travel und Urlaub unverzichtbar.' },
  { title: 'Private Krankenversicherung', href: url('/versicherungen/krankenversicherung/'), description: 'Studentische KV, Familienversicherung oder PKV — was passt zu Ihrer Situation?' },
];
---

<BaseLayout
  title="Studierende & Azubis absichern — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Studenten und Auszubildende? Haftpflicht, BU, Krankenversicherung — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Studierende & Azubis</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Der Start in die Eigenverantwortung. Ich zeige Ihnen, welche Versicherungen jetzt wichtig sind — und welche noch warten können.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Privatpersonen', href: '/spezialisierungen/#privat' }, { label: 'Lebensphasen', href: '/spezialisierungen/#privat-lebensphasen' }]} current="Studierende & Azubis" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Wenig Budget, klare Prioritäten</h2>
        <p>Als Student oder Azubi ist das Budget knapp. Die gute Nachricht: Sie brauchen nur wenige Versicherungen. Aber die wirklich wichtigen sollten Sie nicht auf die lange Bank schieben — insbesondere die Berufsunfähigkeitsversicherung, die in jungen Jahren deutlich günstiger ist.</p>

        <h2>Das Minimum</h2>
        <ul>
          <li><strong>Krankenversicherung</strong> — Bis 25 sind Sie meist beitragsfrei familienversichert. Danach greift die studentische KV (ca. 110 €/Monat). Azubis sind über den Arbeitgeber pflichtversichert.</li>
          <li><strong>Privathaftpflicht</strong> — Prüfen Sie, ob Sie noch über die Familienpolice der Eltern mitversichert sind (meist bis 25, unverheiratet, Erstausbildung). Falls nicht: ab ca. 40 €/Jahr selbst abschließen.</li>
        </ul>

        <h2>Jetzt abschließen, später profitieren</h2>
        <ul>
          <li><strong>Berufsunfähigkeitsversicherung</strong> — Der wichtigste Tipp: Je jünger und gesünder Sie beim Abschluss sind, desto günstiger der Beitrag — ein Leben lang. Eine BU während des Studiums kostet oft nur 30–60 €/Monat. Wer bis 35 wartet, zahlt schnell das Doppelte.</li>
          <li><strong>Auslandskrankenversicherung</strong> — Für Auslandssemester, Praktika im Ausland oder Reisen. Eine Jahrespolice kostet unter 15 €.</li>
        </ul>

        <h2>Was warten kann</h2>
        <p>Hausrat (erst mit eigenem Haushalt und wertvollem Inventar), Rechtsschutz, Kfz — diese Versicherungen brauchen Sie erst, wenn Sie im Beruf stehen und ein eigenes Einkommen haben.</p>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Studierende & Azubis</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Starthilfe für Ihren Versicherungsschutz</h3>
        <p class="text-slate-300 mb-6">Ich erkläre Ihnen in 20 Minuten, was Sie jetzt brauchen und was warten kann — kostenlos und ohne Verkaufsdruck.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
