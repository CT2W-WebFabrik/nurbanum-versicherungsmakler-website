---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz vor Personen- und Sachschäden — inklusive Obhutschäden an fremder Ware.' },
  { title: 'Kfz-Flottenversicherung', href: url('/versicherungen/kfz-flotten/'), description: 'Alle Fahrzeuge in einem Vertrag — vom Sprinter bis zum 40-Tonner.' },
  { title: 'Geschäftsinhaltsversicherung', href: url('/versicherungen/inhaltsversicherung/'), description: 'Schutz für Lagerbestände, Handelsware und Betriebseinrichtung.' },
  { title: 'Betriebsunterbrechungsversicherung', href: url('/versicherungen/betriebsunterbrechung/'), description: 'Einnahmenersatz bei Lieferkettenunterbrechung oder Lagerschaden.' },
  { title: 'Cyber-Versicherung', href: url('/versicherungen/cyber/'), description: 'Absicherung gegen Angriffe auf Warenwirtschaft, Versandsysteme und E-Commerce.' },
  { title: 'Firmen-Rechtsschutzversicherung', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Rechtliche Absicherung bei Streitigkeiten mit Frachtführern, Kunden oder Zoll.' },
];
---

<BaseLayout
  title="Versicherungen für Handel, Transport & Logistik — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Speditionen, Logistiker und Handelsunternehmen? Betriebshaftpflicht, Kfz-Flotte, Transportversicherung — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Handel, Transport & Logistik</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Warenströme, Fuhrpark, Lagerrisiken — die Logistikbranche braucht maßgeschneiderten Versicherungsschutz. Ich kenne die Risiken und finde die passende Lösung.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Handwerk, Handel & Industrie', href: '/spezialisierungen/#gewerbe-handwerk-handel-industrie' }]} current="Handel, Transport & Logistik" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Besondere Risiken im Handel und in der Logistik</h2>
        <p>Wer Waren lagert, transportiert oder handelt, hat fremdes Eigentum in seiner Obhut. Ein Lagerbrand, ein Transportschaden oder ein Diebstahl aus dem Lkw — die Haftung trifft den Spediteur, den Lagerhalter oder den Händler. Gleichzeitig sind Logistikbetriebe auf einen funktionierenden Fuhrpark, reibungslose IT-Systeme und enge Lieferketten angewiesen. Ein Ausfall an einer Stelle kann die gesamte Kette lahmlegen.</p>
        <p>Die Region Nürnberg ist einer der wichtigsten Logistikstandorte Deutschlands — mit dem GVZ Hafen, dem Autobahnkreuz A3/A6/A9 und einer hohen Dichte an Speditions- und Handelsunternehmen.</p>

        <h2>Betriebshaftpflicht und Frachtführerhaftung</h2>
        <p>Die Standard-Betriebshaftpflicht deckt Personen- und Sachschäden gegenüber Dritten. Für Spediteure und Frachtführer reicht das aber nicht: Die gesetzliche Haftung nach §§ 407 ff. HGB (national) und der CMR (international) greift bei Verlust, Beschädigung oder verspäteter Lieferung von Frachtgut. Diese Risiken erfordern eine spezielle Verkehrshaftungsversicherung, die über die Standard-Betriebshaftpflicht hinausgeht.</p>
        <p>Auch Lagerhalter haften nach §§ 467 ff. HGB für Schäden an eingelagerter Ware. Eine Einlagererhaftpflicht deckt dieses Risiko ab.</p>

        <h2>Fuhrpark und Flottenversicherung</h2>
        <p>Lkw, Transporter, Anhänger, Sattelzüge, Kühlfahrzeuge — der Fuhrpark eines Logistikunternehmens ist heterogen und oft das größte Einzelinvestment. Eine Kfz-Flottenversicherung bündelt alle Fahrzeuge in einem Vertrag, vereinfacht die Verwaltung und ermöglicht Mengenrabatte. Neue Fahrzeuge werden unkompliziert hinzugefügt, saisonale Schwankungen berücksichtigt.</p>

        <h2>Lager, Waren und Betriebsunterbrechung</h2>
        <p>Ein Brand im Zentrallager kann für einen Handels- oder Logistikbetrieb existenzbedrohend sein. Die Geschäftsinhaltsversicherung schützt eigene Warenbestände und Betriebseinrichtung. Für eingelagerte Kundenware ist eine separate Einlagererhaftpflicht nötig. Die Betriebsunterbrechungsversicherung ersetzt den entgangenen Gewinn und die Fixkosten, wenn das Lager ausfällt.</p>

        <h2>Digitale Risiken: E-Commerce und Logistik-IT</h2>
        <p>Warenwirtschaftssysteme, Versandplattformen, EDI-Schnittstellen zu Kunden und Lieferanten, Online-Shops — die Logistikbranche ist hochgradig digitalisiert. Ein Ransomware-Angriff kann den gesamten Warenfluss stoppen, ein Systemausfall die Auftragsabwicklung lahmlegen. Die Cyber-Versicherung deckt die Kosten für IT-Forensik, Datenwiederherstellung und Betriebsunterbrechung durch Cyberangriffe.</p>

        <h2>Weitere wichtige Absicherungen</h2>
        <ul>
          <li><strong>Firmen-Rechtsschutz</strong> — Streitigkeiten mit Frachtführern, Kunden, Zollbehörden oder im Arbeitsrecht.</li>
          <li><strong>D&O-Versicherung</strong> — Persönliche Haftung der Geschäftsführung bei Pflichtverletzungen.</li>
          <li><strong>Betriebliche Altersversorgung</strong> — Ein wirksames Instrument zur Fahrerbindung im angespannten Arbeitsmarkt.</li>
        </ul>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Handel & Logistik</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Logistik-Check: Ist Ihr Betrieb richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich analysiere Ihre betrieblichen Risiken und prüfe bestehende Verträge auf Lücken — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Versicherungen für Handel, Transport & Logistik",
    "description": "Welche Versicherungen brauchen Speditionen, Logistiker und Handelsunternehmen? Betriebshaftpflicht, Kfz-Flotte, Transportversicherung — unabhängige Beratung.",
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
