---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Pflichtversicherung für planende Berufe — Schutz bei Planungsfehlern und Bauschäden.' },
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz bei Personen- und Sachschäden auf der Baustelle und im Büro.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Persönliche Haftung bei Geschäftsführung einer Planungsgesellschaft.' },
  { title: 'Firmen-Rechtsschutz', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Schutz bei Honorarstreitigkeiten, Vertragsrecht und Baumängel-Prozessen.' },
  { title: 'Berufsunfähigkeitsversicherung', href: url('/versicherungen/berufsunfaehigkeit/'), description: 'Einkommensschutz für Freiberufler ohne Arbeitgeber-Netz.' },
];
---

<BaseLayout
  title="Architekten & Ingenieure absichern — Nurbanum Versicherungsmakler"
  description="Berufshaftpflicht, Planungsfehler, D&O — Versicherungen für Architekten und Ingenieure. Unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Architekten & Ingenieure</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Planungsfehler können Millionenschäden verursachen. Ich finde den Berufshaftpflichtschutz, der zu Ihrem Tätigkeitsprofil passt.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Freie Berufe & Dienstleistung', href: '/spezialisierungen/#gewerbe-freie-berufe-dienstleistung' }]} current="Architekten & Ingenieure" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Berufshaftpflicht: Kernstück Ihrer Absicherung</h2>
        <p>Für Architekten und bauvorlageberechtigte Ingenieure ist die Berufshaftpflichtversicherung in den meisten Landesbauordnungen Pflicht. Sie deckt Vermögensschäden durch Planungs-, Beratungs- und Überwachungsfehler ab. Die Deckungssummen müssen zum Projektvolumen passen — bei Großprojekten sind 3–5 Millionen Euro keine Seltenheit.</p>
        <h2>Besondere Risiken</h2>
        <ul>
          <li><strong>Planungsfehler mit Spätfolgen</strong> — Baumängel zeigen sich oft erst Jahre nach der Fertigstellung. Die Verjährungsfrist im Baurecht beträgt 5 Jahre — Ihre Versicherung muss auch Nachhaftungsansprüche abdecken.</li>
          <li><strong>HOAI und Honorarstreitigkeiten</strong> — Streitigkeiten über das Honorar sind im Bauwesen häufig. Ein Firmen-Rechtsschutz schützt vor den Prozesskosten.</li>
          <li><strong>Bauüberwachung</strong> — Fehler in der Bauüberwachung können zu Personen- und Sachschäden führen. Prüfen Sie, ob diese Tätigkeit in Ihrer Berufshaftpflicht eingeschlossen ist.</li>
        </ul>
        <h2>Für Planungsbüros und Gesellschaften</h2>
        <p>Wenn Sie ein Planungsbüro als GmbH oder Partnerschaftsgesellschaft führen, kommen D&O-Versicherung, Cyber-Schutz (für CAD-Daten und Planungsunterlagen) und betriebliche Altersversorgung für Ihre Mitarbeiter hinzu.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Architekten & Ingenieure</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Berufshaftpflicht-Check für Planer</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihre bestehende Berufshaftpflicht auf Lücken und finde bei Bedarf bessere Konditionen — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>
</BaseLayout>
