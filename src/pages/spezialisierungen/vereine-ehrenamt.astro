---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Vereinshaftpflicht: Schutz bei Personen- und Sachschäden durch Vereinsaktivitäten und Veranstaltungen.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Schutz für Vorstände und Ehrenamtliche vor persönlicher Haftung bei Pflichtverletzungen.' },
  { title: 'Geschäftsinhaltsversicherung', href: url('/versicherungen/inhaltsversicherung/'), description: 'Absicherung von Vereinsausrüstung, Instrumenten, Sportgeräten und Mobiliar.' },
  { title: 'Unfallversicherung', href: url('/versicherungen/unfallversicherung/'), description: 'Gruppen-Unfallschutz für Mitglieder und Helfer bei Vereinstätigkeiten.' },
  { title: 'Vermögensschadenhaftpflicht', href: url('/versicherungen/vermoegensshadenhaftpflicht/'), description: 'Schutz vor Ansprüchen wegen finanzieller Fehler durch Vorstand oder Kassenwart.' },
  { title: 'Rechtsschutzversicherung', href: url('/versicherungen/rechtsschutz/'), description: 'Rechtliche Absicherung bei Streitigkeiten mit Mitgliedern, Vermietern oder Behörden.' },
];
---

<BaseLayout
  title="Versicherungen für Vereine & Ehrenamt — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Vereine und ehrenamtliche Organisationen? Vereinshaftpflicht, D&O für Vorstände, Unfallschutz — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Vereine & Ehrenamt</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Sportverein, Kulturverein, Förderverein — ehrenamtliches Engagement braucht den richtigen Versicherungsschutz. Ich sorge dafür, dass Verein und Vorstand abgesichert sind.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Vereine & Organisationen', href: '/spezialisierungen/#gewerbe' }]} current="Vereine & Ehrenamt" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Warum brauchen Vereine Versicherungsschutz?</h2>
        <p>Ein eingetragener Verein ist eine juristische Person — er kann verklagt werden und haftet für Schäden. Gleichzeitig tragen Vorstandsmitglieder eine persönliche Verantwortung für die ordnungsgemäße Führung des Vereins. Die gesetzliche Unfallversicherung gilt nur für Beschäftigte, nicht für ehrenamtliche Helfer und Mitglieder. Bei Veranstaltungen, Trainings und Vereinsfahrten bestehen erhebliche Haftungsrisiken.</p>
        <p>Franken ist eine der vereinsdichtesten Regionen Deutschlands — von Sportvereinen über Musikkapellen bis zu Feuerwehr-Fördervereinen. Trotzdem sind viele Vereine unzureichend versichert, weil sich niemand zuständig fühlt oder das Thema ehrenamtlich „nebenbei" erledigt wird.</p>

        <h2>Vereinshaftpflicht — die Basis</h2>
        <p>Die Vereinshaftpflicht (eine Form der Betriebshaftpflicht) schützt den Verein vor Schadensersatzansprüchen, wenn bei Vereinsaktivitäten Personen verletzt oder Sachen beschädigt werden. Typische Fälle:</p>
        <ul>
          <li>Ein Zuschauer wird beim Sportfest von einem Ball getroffen</li>
          <li>Ein Kind verletzt sich auf dem Vereinsgelände</li>
          <li>Bei einem Vereinsfest wird das gemietete Vereinsheim beschädigt</li>
          <li>Ein Helfer verursacht beim Auf- oder Abbau einen Sachschaden</li>
        </ul>
        <p>Achten Sie auf den Einschluss von Veranstaltungen, Ausflügen und der Nutzung gemieteter Räumlichkeiten.</p>

        <h2>D&O-Versicherung für Vorstände</h2>
        <p>Vereinsvorstände haften nach §§ 31, 42 BGB persönlich für Pflichtverletzungen. Zwar begrenzt § 31a BGB seit 2009 die Haftung ehrenamtlich tätiger Vorstandsmitglieder auf Vorsatz und grobe Fahrlässigkeit — doch der Übergang zwischen einfacher und grober Fahrlässigkeit ist fließend. Eine verspätete Steuererklärung, ein DSGVO-Verstoß oder eine fehlerhafte Kassenführung können schnell als grob fahrlässig eingestuft werden.</p>
        <p>Die D&O-Versicherung schützt Vorstandsmitglieder vor den finanziellen Folgen persönlicher Inanspruchnahme und übernimmt die Kosten der Rechtsverteidigung.</p>

        <h2>Gruppen-Unfallversicherung für Mitglieder und Helfer</h2>
        <p>Die gesetzliche Unfallversicherung greift bei ehrenamtlicher Tätigkeit nur in engen Grenzen. Mitglieder, die beim Training, bei Vereinsfahrten oder auf Veranstaltungen verunglücken, haben häufig keinen gesetzlichen Unfallschutz. Eine Gruppen-Unfallversicherung schließt diese Lücke und schützt alle Aktiven bei Vereinstätigkeiten.</p>

        <h2>Vereinsvermögen und Ausrüstung</h2>
        <p>Sportgeräte, Musikinstrumente, Vereinsmöbel, Technik für Veranstaltungen — auch ein Verein hat schützenswerte Sachwerte. Die Geschäftsinhaltsversicherung deckt diese gegen Feuer, Einbruch, Leitungswasser und Sturm ab. Bei gemieteten Räumlichkeiten ist auch der Schlüsselverlusteinschluss ein wichtiger Baustein.</p>

        <h2>Weitere wichtige Absicherungen</h2>
        <ul>
          <li><strong>Vermögensschadenhaftpflicht</strong> — Schutz bei finanziellen Fehlern des Vorstands oder Kassenwarts (fehlerhafte Buchführung, verpasste Fristen, Fehlüberweisungen).</li>
          <li><strong>Veranstalterhaftpflicht</strong> — Für Feste, Turniere und Sonderveranstaltungen, die über die reguläre Vereinshaftpflicht hinausgehen.</li>
          <li><strong>Vereins-Rechtsschutz</strong> — Bei Streitigkeiten mit Mitgliedern, Vermietern, Kommunen oder Nachbarn.</li>
        </ul>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Vereine</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Vereins-Check: Ist Ihr Verein richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe den Versicherungsschutz Ihres Vereins und zeige Ihnen, wo Handlungsbedarf besteht — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
