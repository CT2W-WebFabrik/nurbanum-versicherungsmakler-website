---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Pflegeversicherung', href: url('/versicherungen/pflegeversicherung/'), description: 'Die gesetzliche Pflege deckt nur einen Bruchteil — schließen Sie die Pflegelücke rechtzeitig.' },
  { title: 'Sterbegeldversicherung', href: url('/versicherungen/sterbegeldversicherung/'), description: 'Bestattungskosten absichern und Angehörige finanziell entlasten.' },
  { title: 'Unfallversicherung', href: url('/versicherungen/unfallversicherung/'), description: 'Schutz bei Unfällen im Alltag — mit altersgerechten Leistungen und Assistance.' },
  { title: 'Auslandskrankenversicherung', href: url('/versicherungen/auslandskrankenversicherung/'), description: 'Für Reisen im Ruhestand — Rücktransport und Behandlung weltweit.' },
  { title: 'Private Krankenversicherung', href: url('/versicherungen/krankenversicherung/'), description: 'Tarifoptimierung, Beitragsentlastung und Wechselmöglichkeiten im Alter.' },
  { title: 'Rechtsschutzversicherung', href: url('/versicherungen/rechtsschutz/'), description: 'Schutz bei Streitigkeiten — Mietrecht, Erbrecht, Patientenverfügung.' },
];
---

<BaseLayout
  title="Senioren & Best Ager absichern — Nurbanum Versicherungsmakler"
  description="Versicherungen ab 50: Pflegezusatz, Sterbegeld, Unfallschutz, Auslandskranken — unabhängige Beratung für die zweite Lebenshälfte."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Senioren & Best Ager</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Ab 50 ändern sich die Prioritäten. Ich helfe Ihnen, Ihren Versicherungsschutz an die neue Lebensphase anzupassen — ohne unnötige Kosten.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Privatpersonen', href: '/spezialisierungen/#privat' }, { label: 'Lebensphasen', href: '/spezialisierungen/#privat-lebensphasen' }]} current="Senioren & Best Ager" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Neue Lebensphase, neue Schwerpunkte</h2>
        <p>Mit 50 beginnt eine Lebensphase, in der sich vieles verändert: Die Kinder werden selbstständig, das Eigenheim ist oft abbezahlt, der Ruhestand rückt näher. Manche Versicherungen werden jetzt wichtiger, andere können Sie reduzieren oder kündigen.</p>

        <h2>Was jetzt Priorität hat</h2>
        <ul>
          <li><strong>Pflegezusatzversicherung</strong> — Das Pflegerisiko steigt mit dem Alter. Die gesetzliche Pflegeversicherung deckt nur einen Teil der Kosten. Je früher Sie eine Zusatzversicherung abschließen, desto günstiger die Beiträge und desto einfacher die Gesundheitsprüfung.</li>
          <li><strong>Unfallversicherung mit Assistance</strong> — Im Alter steigt das Unfallrisiko, und die Folgen sind schwerwiegender. Moderne Tarife bieten neben der Invaliditätsleistung auch Assistance-Leistungen: Menüservice, Haushaltshilfe, Fahrdienste nach einem Unfall.</li>
          <li><strong>Sterbegeldversicherung</strong> — Entlastet die Angehörigen von den Bestattungskosten. Ab 50 sind die Beiträge noch moderat.</li>
          <li><strong>Auslandskrankenversicherung</strong> — Im Ruhestand haben Sie mehr Zeit zum Reisen. Eine Jahrespolice kostet wenig und schützt weltweit.</li>
        </ul>

        <h2>Was Sie anpassen sollten</h2>
        <ul>
          <li><strong>Risikolebensversicherung</strong> — Wenn Kinder selbstständig und Kredite abbezahlt sind, sinkt der Bedarf. Summe reduzieren oder auslaufen lassen.</li>
          <li><strong>Privathaftpflicht</strong> — Vom Familientarif zum Paartarif wechseln, wenn die Kinder eigene Verträge haben.</li>
          <li><strong>PKV</strong> — Im Alter steigen die PKV-Beiträge. Ich prüfe, ob ein interner Tarifwechsel (§ 204 VVG) möglich ist — oft gleiche Leistungen bei niedrigerem Beitrag.</li>
        </ul>

        <h2>Was Sie oft nicht mehr brauchen</h2>
        <p>Kinderabsicherung, Ausbildungsversicherungen und hohe Arbeitsrechtsschutz-Bausteine können in der Regel entfallen. Prüfen Sie auch, ob Doppelversicherungen bestehen.</p>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Senioren</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Versicherungscheck 50+</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihre bestehenden Versicherungen und zeige Ihnen, was Sie behalten, anpassen oder kündigen sollten — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
