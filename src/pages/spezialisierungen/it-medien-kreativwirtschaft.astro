---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Schutz vor Schadensersatz bei Projektfehlern, Terminverzug und Urheberrechtsverletzungen.' },
  { title: 'Vermögensschadenhaftpflicht', href: url('/versicherungen/vermoegensschadenhaftpflicht/'), description: 'Absicherung gegen finanzielle Schäden beim Kunden durch fehlerhafte Beratung oder Software.' },
  { title: 'Cyber-Versicherung', href: url('/versicherungen/cyber/'), description: 'Schutz bei Datenverlust, Hackerangriffen und DSGVO-Verstößen.' },
  { title: 'Elektronikversicherung', href: url('/versicherungen/elektronikversicherung/'), description: 'Allgefahrendeckung für IT-Hardware, Studioausrüstung und Kameratechnik.' },
  { title: 'Betriebsunterbrechungsversicherung', href: url('/versicherungen/betriebsunterbrechung/'), description: 'Einnahmenersatz bei Server-Ausfall, Workspace-Schaden oder Cyberangriff.' },
  { title: 'Firmen-Rechtsschutzversicherung', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Rechtliche Absicherung bei Vertragsstreitigkeiten und Urheberrechtskonflikten.' },
];
---

<BaseLayout
  title="Versicherungen für IT, Medien & Kreativwirtschaft — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen IT-Dienstleister, Agenturen und Kreative? Berufshaftpflicht, Cyber, Vermögensschaden — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">IT, Medien & Kreativwirtschaft</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Software, Agenturen, Design, Film — digitale und kreative Dienstleister brauchen Schutz vor Vermögensschäden, Cyberrisiken und Urheberrechtskonflikten.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Freie Berufe & Dienstleistung', href: '/spezialisierungen/#gewerbe' }]} current="IT, Medien & Kreativwirtschaft" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Besondere Risiken für IT- und Kreativunternehmen</h2>
        <p>In der IT- und Kreativbranche entstehen die größten Schäden nicht durch kaputte Gegenstände, sondern durch finanzielle Verluste beim Kunden: Eine fehlerhafte Software legt die Produktion des Auftraggebers lahm, eine Kampagne verwendet lizenzpflichtige Bilder ohne Genehmigung, ein Projekttermin wird gerissen und der Kunde verpasst seinen Marktstart. Das sind reine Vermögensschäden — die Standard-Betriebshaftpflicht deckt sie nicht.</p>
        <p>Hinzu kommt die Verantwortung für Kundendaten (DSGVO), die Abhängigkeit von teurer Hard- und Software sowie die typisch projektbasierte Einkommensstruktur, die Ausfälle besonders schmerzhaft macht.</p>

        <h2>Berufshaftpflicht und Vermögensschadenhaftpflicht</h2>
        <p>IT-Berater, Softwareentwickler, Webdesigner, Agenturen und Fotografen verursachen typischerweise keine Sachschäden, sondern echte Vermögensschäden: Der Kunde verliert Geld durch Ihren Fehler, ohne dass etwas Physisches beschädigt wurde. Für diese Fälle brauchen Sie eine Berufshaftpflicht oder Vermögensschadenhaftpflicht.</p>
        <p>Typische Schadenbeispiele:</p>
        <ul>
          <li>Ein Software-Bug verursacht Datenverlust beim Kunden</li>
          <li>Eine Agentur verwendet ein urheberrechtlich geschütztes Bild — der Rechteinhaber klagt</li>
          <li>Ein IT-Berater empfiehlt die falsche Systemarchitektur — teure Nachbesserung</li>
          <li>Ein Webshop-Relaunch verzögert sich — der Kunde verliert Umsatz</li>
        </ul>

        <h2>Cyber-Versicherung: Eigenes Risiko und Drittschaden</h2>
        <p>IT- und Kreativunternehmen sind gleichzeitig Angreifer-Ziel und Datenverarbeiter. Sie hosten Kundendaten, verwalten Zugänge, betreiben Server. Ein Ransomware-Angriff kann nicht nur Ihren eigenen Betrieb stilllegen, sondern auch die Systeme Ihrer Kunden gefährden. Die DSGVO macht Datenverarbeiter bei Verstößen direkt haftbar — Bußgelder und Schadensersatz können erheblich sein.</p>
        <p>Die Cyber-Versicherung deckt Incident Response, IT-Forensik, Datenwiederherstellung, Benachrichtigungskosten und Drittansprüche.</p>

        <h2>Equipment und Elektronik absichern</h2>
        <p>Kamera-Ausrüstung auf Location, Hochleistungsrechner im Studio, Server im Rack, mobile Geräte unterwegs beim Kunden — IT- und Kreativunternehmen arbeiten mit teurer, empfindlicher Technik. Die Elektronikversicherung bietet eine Allgefahrendeckung, die über die Geschäftsinhaltsversicherung hinausgeht: auch Bedienungsfehler, Kurzschluss und Überspannung sind versichert.</p>

        <h2>Weitere wichtige Absicherungen</h2>
        <ul>
          <li><strong>D&O-Versicherung</strong> — Für Geschäftsführer von Agenturen und IT-Unternehmen in der Rechtsform einer GmbH.</li>
          <li><strong>Berufsunfähigkeitsversicherung</strong> — Für Solo-Kreative und Freiberufler: Ihr Einkommen hängt an Ihrer Arbeitskraft.</li>
          <li><strong>Krankentagegeld</strong> — Kein Auftraggeber zahlt Lohnfortzahlung an Freelancer.</li>
          <li><strong>Betriebliche Altersversorgung</strong> — In der umkämpften IT-Branche ein wirksames Instrument zur Mitarbeiterbindung.</li>
        </ul>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für IT & Kreative</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">IT- und Kreativ-Check</h3>
        <p class="text-slate-300 mb-6">Ich prüfe, ob Ihr Versicherungsschutz zu Ihren Projekten passt — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
