---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Grundschutz vor Schadenersatzansprüchen Dritter — ab Tag 1.' },
  { title: 'Berufshaftpflichtversicherung', href: url('/versicherungen/berufshaftpflicht/'), description: 'Schutz vor Beratungs- und Planungsfehlern — oft vertraglich gefordert.' },
  { title: 'D&O-Versicherung', href: url('/versicherungen/dno-versicherung/'), description: 'Persönliche Haftung der Geschäftsführung absichern — Investoren erwarten das.' },
  { title: 'Cyber-Versicherung', href: url('/versicherungen/cyber/'), description: 'Datenpannen, Hacking, Ransomware — für Tech-Startups existenzkritisch.' },
  { title: 'Betriebliche Altersversorgung', href: url('/versicherungen/betriebliche-altersversorgung/'), description: 'Recruiting-Vorteil: bAV als attraktiver Mitarbeiter-Benefit.' },
];
---

<BaseLayout
  title="Startups & Gründer absichern — Nurbanum Versicherungsmakler"
  description="Versicherungen für Startups: D&O, Cyber, Berufshaftpflicht — der richtige Schutz in jeder Wachstumsphase."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Startups & Gründer</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Schnelles Wachstum, neue Risiken. Ich begleite Startups von der Gründung bis zur Skalierung mit dem passenden Versicherungsschutz.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Freie Berufe & Dienstleistung', href: '/spezialisierungen/#gewerbe-freie-berufe-dienstleistung' }]} current="Startups & Gründer" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Andere Risiken als etablierte Unternehmen</h2>
        <p>Startups wachsen schnell, haben oft externe Investoren und bewegen sich in Märkten mit hoher Unsicherheit. Das verändert die Risikoprofile — und damit den Versicherungsbedarf. Ein einziger Schadenfall kann in der Frühphase das Ende bedeuten.</p>
        <h2>Phase 1: Gründung</h2>
        <p>Konzentrieren Sie sich auf das Wesentliche: Betriebshaftpflicht, Berufshaftpflicht (bei beratender/entwickelnder Tätigkeit) und eine Cyber-Versicherung. Für Tech-Startups ist die Cyber-Police ab Tag 1 empfohlen.</p>
        <h2>Phase 2: Erste Mitarbeiter & Investoren</h2>
        <p>Sobald Investoren an Bord sind, ist die D&O-Versicherung Pflicht — sie schützt die Geschäftsführung vor persönlicher Haftung. Mit den ersten Mitarbeitern kommen bAV-Pflichten und die Chance, Versicherungsleistungen als Recruiting-Vorteil zu nutzen.</p>
        <h2>Phase 3: Skalierung</h2>
        <p>Mit wachsendem Umsatz und Team steigen die Risiken: Vertrauensschadenversicherung, Rechtsschutz, Produkthaftpflicht und Betriebsunterbrechung werden relevant. Ich passe Ihren Schutz an jede Wachstumsphase an.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Startups</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Startup-Check: Sind Sie richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihren aktuellen Schutz und empfehle, was in Ihrer Wachstumsphase wirklich nötig ist — kostenlos und ohne Verkaufsdruck.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Startups & Gründer absichern",
    "description": "Versicherungen für Startups: D&O, Cyber, Berufshaftpflicht — der richtige Schutz in jeder Wachstumsphase.",
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
