---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Grundschutz bei Personen- und Sachschäden durch Ihre Produkte.' },
  { title: 'Produkthaftpflichtversicherung', href: url('/versicherungen/produkthaftpflicht/'), description: 'Sie haften als Händler für Produktsicherheit — auch bei Import aus Drittländern.' },
  { title: 'Cyber-Versicherung', href: url('/versicherungen/cyber/'), description: 'Ihr Shop ist Ihr Geschäft — Schutz bei Hacking, Datenpannen und DSGVO-Verstößen.' },
  { title: 'Transportversicherung', href: url('/versicherungen/transportversicherung/'), description: 'Warenschutz beim Versand — die Paketversicherung des Logistikers reicht selten.' },
  { title: 'Inhaltsversicherung', href: url('/versicherungen/inhaltsversicherung/'), description: 'Schutz für Ihren Warenbestand im Lager vor Feuer, Einbruch und Wasser.' },
  { title: 'Firmen-Rechtsschutz', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Schutz bei Abmahnungen, Markenrecht und AGB-Streitigkeiten.' },
];
---

<BaseLayout
  title="E-Commerce & Onlinehandel absichern — Nurbanum Versicherungsmakler"
  description="Versicherungen für Onlinehändler: Produkthaftung, Cyber, Transport, Rechtsschutz — Schutz für Ihr digitales Geschäft."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">E-Commerce & Onlinehandel</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Produkthaftung, Cyber-Risiken, Versandschäden — ich kenne die speziellen Anforderungen des Onlinehandels und finde den passenden Schutz.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Handwerk, Handel & Industrie', href: '/spezialisierungen/#gewerbe-handwerk-handel-industrie' }]} current="E-Commerce & Onlinehandel" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Spezielle Risiken im Onlinehandel</h2>
        <p>E-Commerce-Unternehmen verkaufen Produkte, die sie oft nicht selbst herstellen, versenden Waren über Dienstleister, verarbeiten Kundendaten und sind rund um die Uhr online. Jeder dieser Punkte birgt eigene Risiken — Produkthaftung, Transportschäden, Datenpannen und Abmahnungen sind an der Tagesordnung.</p>
        <h2>Produkthaftung: Auch als Händler</h2>
        <p>Als Händler haften Sie für die Sicherheit der Produkte, die Sie verkaufen. Bei Import aus Nicht-EU-Ländern gelten Sie sogar als Quasi-Hersteller. Eine Produkthaftpflichtversicherung ist hier unverzichtbar.</p>
        <h2>Ihr Shop ist Ihr Geschäft</h2>
        <p>Ein Hackerangriff, ein Serverausfall oder eine DSGVO-Datenpanne kann Sie Tage außer Gefecht setzen. Die Cyber-Versicherung übernimmt IT-Forensik, Datenwiederherstellung, Kundenbenachrichtigung und den Umsatzausfall während der Downtime.</p>
        <h2>Versand und Lager</h2>
        <p>Die Haftung des Paketdienstleisters ist auf ca. 500–750 Euro begrenzt. Bei höherwertigen Sendungen brauchen Sie eine Transportversicherung. Und Ihr Warenbestand im Lager ist ohne Inhaltsversicherung bei Brand oder Einbruch ungeschützt.</p>
      </div>
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Onlinehändler</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">Mehr erfahren<svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></span>
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">E-Commerce-Check: Sind Sie richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihren Versicherungsschutz und finde die Lücken — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">Beratungstermin vereinbaren</a>
      </div>
    </div>
  </section>
</BaseLayout>
