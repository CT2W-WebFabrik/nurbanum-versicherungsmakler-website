---
import { url, slugify } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';

const privatSubsections = [
  {
    label: 'Lebensphasen',
    items: [
      { href: url('/spezialisierungen/berufseinsteiger-junge-erwachsene/'), title: 'Berufseinsteiger & junge Erwachsene', description: 'Welche Versicherungen am Karrierestart wirklich wichtig sind — und welche warten können.' },
      { href: url('/spezialisierungen/familien-kinder/'), title: 'Familien & Kinder', description: 'Kinder schützen, Eltern absichern. Die richtige Priorität bei der Familienabsicherung.' },
      { href: url('/spezialisierungen/studierende-azubis/'), title: 'Studierende & Azubis', description: 'Haftpflicht, Hausrat, BU-Starter — die wichtigsten Policen zum kleinen Budget.' },
      { href: url('/spezialisierungen/alleinstehende-singles/'), title: 'Alleinstehende & Singles', description: 'Eigene Absicherung ohne Partner-Netz — BU, Haftpflicht und Vorsorge richtig aufstellen.' },
      { href: url('/spezialisierungen/senioren-best-ager/'), title: 'Senioren & Best Ager', description: 'Versicherungsschutz im Ruhestand anpassen — Überversicherung vermeiden, Lücken schließen.' },
      { href: url('/spezialisierungen/immobilienbesitzer-vermieter/'), title: 'Immobilienbesitzer & Vermieter', description: 'Wohngebäude, Grundbesitzerhaftpflicht, Photovoltaik — Schutz für Ihre Immobilie.' },
      { href: url('/spezialisierungen/expats-auswanderer/'), title: 'Expats & Auswanderer', description: 'Krankenversicherung, Haftpflicht und Altersvorsorge bei Wohnsitz im Ausland.' },
    ],
  },
  {
    label: 'Vorsorge & Ruhestand',
    items: [
      { href: url('/spezialisierungen/altersvorsorge/'), title: 'Private Altersvorsorge', description: 'Riester, Rürup, ETF-Police — welcher Vorsorgeweg passt zu Ihrer Situation?' },
      { href: url('/spezialisierungen/ruhestandsplanung/'), title: 'Ruhestandsplanung', description: 'Den Übergang in den Ruhestand finanziell und versicherungstechnisch vorbereiten.' },
    ],
  },
  {
    label: 'Absicherung im Beruf',
    items: [
      { href: url('/spezialisierungen/betriebliche-altersversorgung/'), title: 'Betriebliche Altersversorgung', description: 'Entgeltumwandlung, Arbeitgeberzuschuss, Durchführungswege — bAV verständlich erklärt.' },
      { href: url('/spezialisierungen/angestellte-gutverdiener/'), title: 'Angestellte & Gutverdiener', description: 'PKV, bAV-Optimierung, Zusatzversicherungen — das Beste aus Ihrem Einkommen herausholen.' },
    ],
  },
];

const gewerbeSubsections = [
  {
    label: 'Freie Berufe & Dienstleistung',
    items: [
      { href: url('/spezialisierungen/selbstaendige-freiberufler/'), title: 'Selbständige & Freiberufler', description: 'Berufshaftpflicht, BU, Krankenversicherung — die wichtigsten Absicherungen ohne Arbeitgeber-Netz.' },
      { href: url('/spezialisierungen/heilberufe-praxen/'), title: 'Heilberufe & Praxen', description: 'Berufshaftpflicht, Cyber, Praxisschutz — für Ärzte, Zahnärzte, Therapeuten und Heilpraktiker.' },
      { href: url('/spezialisierungen/it-medien-kreativwirtschaft/'), title: 'IT, Medien & Kreativwirtschaft', description: 'Vermögensschadenhaftpflicht, Cyber, Elektronik — Schutz für digitale und kreative Dienstleister.' },
      { href: url('/spezialisierungen/startups-gruender/'), title: 'Startups & Gründer', description: 'Betriebshaftpflicht, D&O, Cyber — die wichtigsten Versicherungen für junge Unternehmen.' },
      { href: url('/spezialisierungen/architekten-ingenieure/'), title: 'Architekten & Ingenieure', description: 'Pflicht-Berufshaftpflicht, D&O, Firmen-Rechtsschutz — Schutz für planende Berufe.' },
      { href: url('/spezialisierungen/rechtsanwaelte-steuerberater/'), title: 'Rechtsanwälte & Steuerberater', description: 'Berufshaftpflicht über die Pflichtversicherung hinaus, Cyber, D&O — Schutz für Kanzleien.' },
      { href: url('/spezialisierungen/immobilienverwaltungen/'), title: 'Immobilienverwaltungen', description: 'Vermögensschadenhaftpflicht, D&O, Cyber — Schutz für WEG- und Mietverwalter.' },
    ],
  },
  {
    label: 'Handwerk, Handel & Industrie',
    items: [
      { href: url('/spezialisierungen/handwerk-baubetriebe/'), title: 'Handwerk & Baubetriebe', description: 'Betriebshaftpflicht, Maschinenversicherung, Kfz-Flotte — Schutz für den Handwerksbetrieb.' },
      { href: url('/spezialisierungen/gastronomie-hotellerie/'), title: 'Gastronomie & Hotellerie', description: 'Betriebshaftpflicht, Inhaltsversicherung, Produkthaftung — Schutz für Ihren Gastrobetrieb.' },
      { href: url('/spezialisierungen/produktion-industrie/'), title: 'Produzierendes Gewerbe & Industrie', description: 'Produkthaftpflicht, Maschinenversicherung, Umwelthaftpflicht — Schutz für Industriebetriebe.' },
      { href: url('/spezialisierungen/handel-transport-logistik/'), title: 'Handel, Transport & Logistik', description: 'Frachtführerhaftung, Kfz-Flotte, Lagerrisiken — Schutz für Speditionen und Handelsunternehmen.' },
      { href: url('/spezialisierungen/e-commerce-onlinehandel/'), title: 'E-Commerce & Onlinehandel', description: 'Produkthaftpflicht, Cyber, Rechtsschutz — Schutz für Online-Shops und digitale Geschäftsmodelle.' },
      { href: url('/spezialisierungen/land-forstwirtschaft/'), title: 'Land- & Forstwirtschaft', description: 'Betriebshaftpflicht, Maschinen, Gebäude — Versicherungsschutz für landwirtschaftliche Betriebe.' },
      { href: url('/spezialisierungen/bautraeger-projektentwickler/'), title: 'Bauträger & Projektentwickler', description: 'Bauleistung, Berufshaftpflicht, D&O — Schutz für komplexe Bauprojekte.' },
    ],
  },
  {
    label: 'Vereine & Organisationen',
    items: [
      { href: url('/spezialisierungen/vereine-ehrenamt/'), title: 'Vereine & Ehrenamt', description: 'Vereinshaftpflicht, D&O für Vorstände, Unfallschutz — Schutz für ehrenamtliches Engagement.' },
      { href: url('/spezialisierungen/soziale-einrichtungen-pflege/'), title: 'Soziale Einrichtungen & Pflege', description: 'Kitas, Pflegeheime, soziale Träger — Haftpflicht, D&O, Cyber und Berufshaftpflicht für soziale Organisationen.' },
    ],
  },
];

const privatCount = privatSubsections.reduce((sum, s) => sum + s.items.length, 0);
const gewerbeCount = gewerbeSubsections.reduce((sum, s) => sum + s.items.length, 0);
---

<BaseLayout
  title="Spezialisierungen — Nurbanum Versicherungsmakler"
  description="Versicherungsberatung für Ihre Lebenssituation: Familien, Berufseinsteiger, Selbständige, Handwerker, Gastronomen, IT-Unternehmen und mehr."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierungen</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up" style="animation-delay: 0.1s;">Beratung für Ihre Situation</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        Jede Lebenssituation und jede Branche bringt eigene Risiken mit sich. Ich zeige Ihnen, welche Versicherungen für Sie wirklich wichtig sind.
      </p>
    </div>
  </section>

  <!-- Sticky navigation: tabs + search -->
  <div class="bg-white border-b border-slate-200 sticky top-16 sm:top-[6.25rem] z-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 py-3">
        <nav class="flex gap-1 overflow-x-auto" aria-label="Spezialisierungskategorien">
          <button
            data-tab="privat"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-amber-100 text-amber-800"
            aria-pressed="true"
          >
            Für Privatpersonen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{privatCount}</span>
          </button>
          <button
            data-tab="gewerbe"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-slate-50 text-navy-700 hover:text-amber-700 hover:bg-amber-50"
            aria-pressed="false"
          >
            Für Unternehmen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{gewerbeCount}</span>
          </button>
        </nav>
        <div class="sm:ml-auto relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="search"
            id="page-search"
            placeholder="Spezialisierung suchen…"
            class="w-full sm:w-64 pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-lg bg-slate-50 text-navy-950 placeholder-slate-400 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Für Privatpersonen -->
  <section id="privat" data-audience="privat" class="py-20 sm:py-28 bg-pattern scroll-mt-28 sm:scroll-mt-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Privatpersonen & Familien</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Spezialisierungen für Privatpersonen</h2>
      </div>

      {privatSubsections.map((sub, index) => (
        <div id={`privat-${slugify(sub.label)}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-navy-50/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-privat-${slugify(sub.label)}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {sub.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{sub.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-privat-${slugify(sub.label)}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {sub.items.map((item) => (
                  <a
                    href={item.href}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${item.title} ${item.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {item.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {item.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Spezialisierung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <!-- Für Unternehmen -->
  <section id="gewerbe" data-audience="gewerbe" class="py-20 sm:py-28 bg-navy-50/50 hidden scroll-mt-28 sm:scroll-mt-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Unternehmen & Selbständige</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Spezialisierungen für Unternehmen</h2>
      </div>

      {gewerbeSubsections.map((sub, index) => (
        <div id={`gewerbe-${slugify(sub.label)}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-white/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-gewerbe-${slugify(sub.label)}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {sub.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{sub.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-gewerbe-${slugify(sub.label)}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {sub.items.map((item) => (
                  <a
                    href={item.href}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${item.title} ${item.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {item.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {item.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Spezialisierung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <script>
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
    const sections = document.querySelectorAll<HTMLElement>('[data-audience]');
    const searchInput = document.getElementById('page-search') as HTMLInputElement | null;

    function setTab(audience: string) {
      tabBtns.forEach(btn => {
        const active = btn.dataset.tab === audience;
        btn.setAttribute('aria-pressed', String(active));
        btn.className = `tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap ${
          active ? 'bg-amber-100 text-amber-800' : 'bg-slate-50 text-navy-700 hover:text-amber-700 hover:bg-amber-50'
        }`;
      });
      sections.forEach(s => s.classList.toggle('hidden', s.dataset.audience !== audience));
      applySearch();
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        setTab(btn.dataset.tab!);
        history.replaceState(null, '', `#${btn.dataset.tab}`);
      });
    });

    // Accordion — exclusive: opening one closes others in the same section
    document.querySelectorAll<HTMLButtonElement>('.accordion-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const section = btn.closest('[data-audience]');
        if (section && !expanded) {
          section.querySelectorAll<HTMLButtonElement>('.accordion-toggle').forEach(other => {
            if (other !== btn) {
              other.setAttribute('aria-expanded', 'false');
              const ob = document.getElementById(other.getAttribute('aria-controls') || '');
              if (ob) ob.dataset.open = 'false';
            }
          });
        }
        btn.setAttribute('aria-expanded', String(!expanded));
        const body = document.getElementById(btn.getAttribute('aria-controls') || '');
        if (body) body.dataset.open = String(!expanded);
      });
    });

    // Search
    function applySearch() {
      const q = (searchInput?.value || '').toLowerCase().trim();
      sections.forEach(section => {
        if (section.classList.contains('hidden')) return;
        const cards = section.querySelectorAll<HTMLElement>('.search-card');
        const accordions = section.querySelectorAll<HTMLElement>('.category-accordion');
        const noResults = section.querySelector<HTMLElement>('.no-results');
        let total = 0;

        cards.forEach(card => {
          const match = !q || (card.dataset.search || '').includes(q);
          card.classList.toggle('hidden', !match);
          if (match) total++;
        });

        accordions.forEach(acc => {
          const visible = acc.querySelectorAll('.search-card:not(.hidden)').length;
          acc.classList.toggle('hidden', visible === 0);
          if (q && visible > 0) {
            const toggle = acc.querySelector<HTMLButtonElement>('.accordion-toggle');
            toggle?.setAttribute('aria-expanded', 'true');
            const body = document.getElementById(toggle?.getAttribute('aria-controls') || '');
            if (body) body.dataset.open = 'true';
          }
        });

        if (noResults) noResults.classList.toggle('hidden', total > 0 || !q);
      });
    }

    searchInput?.addEventListener('input', applySearch);

    document.querySelectorAll('.clear-search').forEach(btn => {
      btn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        sections.forEach(section => {
          section.querySelectorAll<HTMLElement>('.category-accordion').forEach((acc, i) => {
            acc.classList.remove('hidden');
            const toggle = acc.querySelector<HTMLButtonElement>('.accordion-toggle');
            toggle?.setAttribute('aria-expanded', String(i === 0));
            const body = document.getElementById(toggle?.getAttribute('aria-controls') || '');
            if (body) body.dataset.open = String(i === 0);
          });
          section.querySelectorAll<HTMLElement>('.search-card').forEach(c => c.classList.remove('hidden'));
          section.querySelector<HTMLElement>('.no-results')?.classList.add('hidden');
        });
      });
    });

    // URL hash handling
    const hash = location.hash.slice(1);
    const audience = hash.startsWith('gewerbe') ? 'gewerbe' : 'privat';
    setTab(audience);

    if (hash.includes('-')) {
      const el = document.getElementById(hash);
      if (el) {
        const section = el.closest('[data-audience]');
        if (section) {
          section.querySelectorAll<HTMLButtonElement>('.accordion-toggle').forEach(other => {
            other.setAttribute('aria-expanded', 'false');
            const ob = document.getElementById(other.getAttribute('aria-controls') || '');
            if (ob) ob.dataset.open = 'false';
          });
        }
        const toggle = el.querySelector<HTMLButtonElement>('.accordion-toggle');
        if (toggle) {
          toggle.setAttribute('aria-expanded', 'true');
          const body = document.getElementById(toggle.getAttribute('aria-controls') || '');
          if (body) body.dataset.open = 'true';
          setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
        }
      }
    }
  </script>
</BaseLayout>
