---
import { url, slugify } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../config';

const entries = await getCollection('spezialisierungen');

type CardItem = { href: string; title: string; description: string };
type Subsection = { label: string; items: CardItem[] };

const privatCategoryOrder = ['Lebensphasen', 'Vorsorge & Ruhestand', 'Absicherung im Beruf'];
const gewerbeCategoryOrder = ['Freie Berufe & Dienstleistung', 'Handwerk, Handel & Industrie', 'Vereine & Organisationen'];

function buildSubsections(audience: 'privat' | 'gewerbe', categoryOrder: string[]): Subsection[] {
  const filtered = entries.filter(e => e.data.audience === audience);
  const grouped = new Map<string, CardItem[]>();
  for (const entry of filtered) {
    const cat = entry.data.category;
    if (!grouped.has(cat)) grouped.set(cat, []);
    grouped.get(cat)!.push({
      href: url(`/spezialisierungen/${entry.id}/`),
      title: entry.data.h1,
      description: entry.data.heroDescription,
    });
  }
  for (const items of grouped.values()) {
    items.sort((a, b) => a.title.localeCompare(b.title, 'de'));
  }
  const result: Subsection[] = [];
  for (const cat of categoryOrder) {
    if (grouped.has(cat)) {
      result.push({ label: cat, items: grouped.get(cat)! });
      grouped.delete(cat);
    }
  }
  for (const [cat, items] of grouped) {
    result.push({ label: cat, items });
  }
  return result;
}

const privatSubsections = buildSubsections('privat', privatCategoryOrder);
const gewerbeSubsections = buildSubsections('gewerbe', gewerbeCategoryOrder);

const privatCount = privatSubsections.reduce((sum, s) => sum + s.items.length, 0);
const gewerbeCount = gewerbeSubsections.reduce((sum, s) => sum + s.items.length, 0);
---

<BaseLayout
  title="Spezialisierungen — Nurbanum Versicherungsmakler"
  description="Versicherungsberatung für Ihre Lebenssituation: Familien, Berufseinsteiger, Selbständige, Handwerker, Gastronomen, IT-Unternehmen und mehr."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierungen</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up" style="animation-delay: 0.1s;">Beratung für Ihre Situation</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        Jede Lebenssituation und jede Branche bringt eigene Risiken mit sich. Ich zeige Ihnen, welche Versicherungen für Sie wirklich wichtig sind.
      </p>
    </div>
  </section>

  <!-- Sticky navigation: tabs + search -->
  <div class="bg-white border-b border-slate-200 sticky top-16 sm:top-[6.25rem] z-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 py-3">
        <nav class="flex gap-1 overflow-x-auto" aria-label="Spezialisierungskategorien">
          <button
            data-tab="privat"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-amber-100 text-amber-800"
            aria-pressed="true"
          >
            Für Privatpersonen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{privatCount}</span>
          </button>
          <button
            data-tab="gewerbe"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-slate-50 text-navy-700 hover:text-amber-700 hover:bg-amber-50"
            aria-pressed="false"
          >
            Für Unternehmen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{gewerbeCount}</span>
          </button>
        </nav>
        <div class="sm:ml-auto relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="search"
            id="page-search"
            placeholder="Spezialisierung suchen…"
            class="w-full sm:w-64 pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-lg bg-slate-50 text-navy-950 placeholder-slate-400 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Für Privatpersonen -->
  <section id="privat" data-audience="privat" class="py-20 sm:py-28 bg-pattern scroll-mt-28 sm:scroll-mt-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Privatpersonen & Familien</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Spezialisierungen für Privatpersonen</h2>
      </div>

      {privatSubsections.map((sub, index) => (
        <div id={`privat-${slugify(sub.label)}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-navy-50/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-privat-${slugify(sub.label)}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {sub.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{sub.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-privat-${slugify(sub.label)}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {sub.items.map((item) => (
                  <a
                    href={item.href}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${item.title} ${item.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {item.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {item.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Spezialisierung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <!-- Für Unternehmen -->
  <section id="gewerbe" data-audience="gewerbe" class="py-20 sm:py-28 bg-navy-50/50 hidden scroll-mt-28 sm:scroll-mt-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Unternehmen & Selbständige</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Spezialisierungen für Unternehmen</h2>
      </div>

      {gewerbeSubsections.map((sub, index) => (
        <div id={`gewerbe-${slugify(sub.label)}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-white/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-gewerbe-${slugify(sub.label)}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {sub.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{sub.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-gewerbe-${slugify(sub.label)}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {sub.items.map((item) => (
                  <a
                    href={item.href}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${item.title} ${item.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {item.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {item.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Spezialisierung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <script>
    import { initTabAccordionSearch } from '../../scripts/tab-accordion-search';
    initTabAccordionSearch({ searchInputId: 'page-search', cardSelector: '.search-card' });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Spezialisierungen — Nurbanum Versicherungsmakler",
    "description": "Zielgruppengerechte Versicherungsberatung: Von Berufseinsteigern über Familien bis zu Handwerksbetrieben.",
    "publisher": { "@id": `${SITE_URL}/#organization` }
  })} />
</BaseLayout>
