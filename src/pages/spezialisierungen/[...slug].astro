---
import { url, slugify } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { SITE_URL } from '../../config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('spezialisierungen');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const audienceLabel = entry.data.audience === 'gewerbe' ? 'Für Unternehmen' : 'Für Privatpersonen';
const audienceAnchor = entry.data.audience;
---

<BaseLayout
  title={`${entry.data.title} — Nurbanum Versicherungsmakler`}
  description={entry.data.description}
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">{entry.data.h1}</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">{entry.data.heroDescription}</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: 'Spezialisierungen', href: '/spezialisierungen/' },
        { label: audienceLabel, href: `/spezialisierungen/#${audienceAnchor}` },
        { label: entry.data.category, href: `/spezialisierungen/#${audienceAnchor}-${slugify(entry.data.category)}` },
      ]} current={entry.data.h1} />

      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <TableOfContents headings={headings} />
        <Content />
      </div>

      {entry.data.productLinks && entry.data.productLinks.length > 0 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen</h2>
          <div class="grid sm:grid-cols-2 gap-5">
            {entry.data.productLinks.map(product => (
              <a href={url(product.href)} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
                <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
                <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                  Mehr erfahren
                  <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": entry.data.title,
    "description": entry.data.description,
    "provider": { "@id": `${SITE_URL}/#organization` },
    "serviceType": "Versicherungsvermittlung",
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
