---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Kinderabsicherung', href: url('/versicherungen/kinderabsicherung/'), description: 'Unfallschutz, Invaliditätsversicherung und Gesundheitsvorsorge für Kinder.' },
  { title: 'Risikolebensversicherung', href: url('/versicherungen/risikoleben/'), description: 'Finanzielle Absicherung der Familie im Todesfall eines Elternteils.' },
  { title: 'Privathaftpflichtversicherung', href: url('/versicherungen/haftpflicht/'), description: 'Familientarif mit Einschluss deliktunfähiger Kinder unter 7 Jahren.' },
  { title: 'Zahnzusatzversicherung', href: url('/versicherungen/zahnzusatzversicherung/'), description: 'Kieferorthopädie, Zahnersatz und Prophylaxe für die ganze Familie.' },
  { title: 'Unfallversicherung', href: url('/versicherungen/unfallversicherung/'), description: 'Schutz bei dauerhaften Unfallfolgen — besonders wichtig für Kinder in der Freizeit.' },
  { title: 'Berufsunfähigkeitsversicherung', href: url('/versicherungen/berufsunfaehigkeit/'), description: 'Das Familieneinkommen absichern — frühzeitiger Abschluss spart Beiträge.' },
];
---

<BaseLayout
  title="Familien & Kinder absichern — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Familien mit Kindern? Kinderabsicherung, Risikoleben, Haftpflicht, Zahnzusatz — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Familien & Kinder</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Kinder schützen, Eltern absichern. Ich zeige Ihnen, welche Versicherungen für Ihre Familie wirklich wichtig sind — und welche Sie sich sparen können.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Privatpersonen', href: '/spezialisierungen/#privat' }, { label: 'Lebensphasen', href: '/spezialisierungen/#privat-lebensphasen' }]} current="Familien & Kinder" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Warum ist Familienabsicherung so wichtig?</h2>
        <p>Mit der Geburt eines Kindes verändert sich die finanzielle Verantwortung grundlegend. Plötzlich hängt nicht nur das eigene Wohlergehen, sondern die Zukunft einer ganzen Familie von der richtigen Absicherung ab. Die gute Nachricht: Sie brauchen keine zehn verschiedenen Policen. Die schlechte: Die wirklich wichtigen Versicherungen sollten Sie nicht auf die lange Bank schieben.</p>

        <h2>Priorität 1: Eltern absichern</h2>
        <p>Der größte finanzielle Hebel liegt bei den Eltern, nicht bei den Kindern. Wenn ein Elternteil stirbt oder berufsunfähig wird, bricht das Familieneinkommen weg. Deshalb stehen diese beiden Versicherungen ganz oben:</p>
        <ul>
          <li><strong>Risikolebensversicherung</strong> — Sichert die Familie finanziell ab, wenn ein Elternteil verstirbt. Empfohlene Summe: mindestens das Fünffache des Bruttojahreseinkommens. Bei einem Immobilienkredit entsprechend höher.</li>
          <li><strong>Berufsunfähigkeitsversicherung</strong> — Schützt das monatliche Einkommen, wenn Sie aus gesundheitlichen Gründen nicht mehr arbeiten können. Je früher der Abschluss, desto günstiger die Beiträge und desto weniger Gesundheitsfragen.</li>
        </ul>

        <h2>Priorität 2: Kinder schützen</h2>
        <ul>
          <li><strong>Privathaftpflicht mit Familientarif</strong> — Kinder unter 7 Jahren (im Straßenverkehr unter 10) sind deliktunfähig und haften nicht selbst. Dennoch sollten Sie einen Tarif mit Einschluss deliktunfähiger Kinder wählen, damit Nachbarschaftskonflikte nach Sachschäden nicht eskalieren.</li>
          <li><strong>Kinderunfallversicherung</strong> — Die gesetzliche Unfallversicherung schützt nur in Kita und Schule. In der Freizeit — also dort, wo die meisten Unfälle passieren — besteht kein gesetzlicher Schutz. Die private Kinderunfallversicherung schließt diese Lücke.</li>
          <li><strong>Kinderinvaliditätsversicherung</strong> — Geht über den Unfallschutz hinaus und leistet auch bei Invalidität durch Krankheit (z. B. Krebs, Diabetes, Epilepsie).</li>
        </ul>

        <h2>Sinnvolle Ergänzungen</h2>
        <ul>
          <li><strong>Zahnzusatzversicherung für Kinder</strong> — Kieferorthopädie (Zahnspange) ist nur bei schweren Fehlstellungen eine Kassenleistung. Schließen Sie die Versicherung ab, bevor der Kieferorthopäde einen Behandlungsbedarf feststellt.</li>
          <li><strong>Auslandsreise-Krankenversicherung</strong> — Für den Familienurlaub unverzichtbar. Eine Jahresfamilien-Police kostet oft unter 30 Euro.</li>
        </ul>

        <h2>Was Familien oft nicht brauchen</h2>
        <p>Nicht jede Versicherung ist sinnvoll. Ausbildungsversicherungen, Sterbegeldversicherungen für Kinder und kapitalbildende Kinderversicherungen sind in den meisten Fällen zu teuer für das, was sie leisten. Sprechen Sie mich an, bevor Sie diese abschließen.</p>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Familien</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Familiencheck: Sind Sie richtig abgesichert?</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihre bestehenden Versicherungen und zeige Ihnen, wo Handlungsbedarf besteht — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
