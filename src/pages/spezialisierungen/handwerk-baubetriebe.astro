---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const relevantProducts = [
  { title: 'Betriebshaftpflichtversicherung', href: url('/versicherungen/betriebshaftpflicht/'), description: 'Schutz vor Schadensersatz bei Personen- und Sachschäden durch Ihre betriebliche Tätigkeit.' },
  { title: 'Maschinenversicherung', href: url('/versicherungen/maschinenversicherung/'), description: 'Allgefahrendeckung für Baumaschinen, Werkzeugmaschinen und mobile Geräte.' },
  { title: 'Betriebsunterbrechungsversicherung', href: url('/versicherungen/betriebsunterbrechung/'), description: 'Sichert Ihre laufenden Kosten und entgangenen Gewinn bei Betriebsstillstand.' },
  { title: 'Kfz-Flottenversicherung', href: url('/versicherungen/kfz-flotten/'), description: 'Alle Firmenfahrzeuge in einem Vertrag — vom Transporter bis zum Bagger.' },
  { title: 'Geschäftsinhaltsversicherung', href: url('/versicherungen/inhaltsversicherung/'), description: 'Schutz für Werkzeuge, Materialien und Betriebseinrichtung auf der Baustelle und im Betrieb.' },
  { title: 'Firmen-Rechtsschutzversicherung', href: url('/versicherungen/firmen-rechtsschutz/'), description: 'Rechtliche Absicherung bei Streitigkeiten mit Auftraggebern, Lieferanten oder Behörden.' },
];
---

<BaseLayout
  title="Versicherungen für Handwerk & Baubetriebe — Nurbanum Versicherungsmakler"
  description="Welche Versicherungen brauchen Handwerker und Baubetriebe? Betriebshaftpflicht, Maschinenversicherung, Kfz-Flotte — unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Spezialisierung</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Handwerk & Baubetriebe</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.15s;">Auf der Baustelle, in der Werkstatt, beim Kunden — Handwerker tragen besondere Risiken. Ich sorge dafür, dass Ihr Betrieb richtig abgesichert ist.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: 'Spezialisierungen', href: '/spezialisierungen/' }, { label: 'Für Unternehmen', href: '/spezialisierungen/#gewerbe' }, { label: 'Handwerk, Handel & Industrie', href: '/spezialisierungen/#gewerbe-handwerk-handel-industrie' }]} current="Handwerk & Baubetriebe" />
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">

        <h2>Warum ist der Versicherungsschutz im Handwerk so wichtig?</h2>
        <p>Handwerker und Baubetriebe arbeiten mit schweren Maschinen, auf fremden Grundstücken und unter Zeitdruck. Ein Moment der Unachtsamkeit — und ein Wasserschaden beim Kunden, ein Gerüstunfall oder ein defektes Werkstück können existenzbedrohende Schadenssummen verursachen. Gleichzeitig sind teure Maschinen und Fahrzeuge das Rückgrat Ihres Betriebs. Fällt eine Kernmaschine aus, steht der Betrieb still.</p>

        <h2>Pflicht und Grundlage: Betriebshaftpflicht</h2>
        <p>Die Betriebshaftpflichtversicherung ist für jeden Handwerksbetrieb unverzichtbar. Sie schützt Sie, wenn durch Ihre Arbeit Personen verletzt oder Sachen beschädigt werden. Typische Fälle: Ein Elektriker verursacht einen Kurzschluss beim Kunden, ein Dachdecker beschädigt die Fassade des Nachbarhauses, ein Installateur übersieht ein Leck.</p>
        <p>Achten Sie auf ausreichende Deckungssummen (mindestens 5 Millionen Euro) und darauf, dass Tätigkeits- und Bearbeitungsschäden mitversichert sind — also Schäden an den Sachen, an denen Sie gerade arbeiten.</p>

        <h2>Maschinen und Werkzeuge absichern</h2>
        <p>Ob CNC-Fräse in der Werkstatt, Minibagger auf der Baustelle oder Spezialwerkzeug im Transporter — die Maschinenversicherung deckt Schäden durch Bedienungsfehler, Kurzschluss, Material- und Konstruktionsfehler sowie Vandalismus. Eine Allgefahrendeckung schützt gegen alles, was nicht ausdrücklich ausgeschlossen ist.</p>
        <p>Für mobile Maschinen und Geräte, die auf wechselnden Baustellen eingesetzt werden, gibt es spezielle Bauleistungs- und Baugeräteversicherungen.</p>

        <h2>Fuhrpark und Flottenversicherung</h2>
        <p>Transporter, Pritschenwagen, Anhänger, vielleicht ein Bagger oder Radlader — Handwerksbetriebe haben oft einen heterogenen Fuhrpark. Eine Kfz-Flottenversicherung bündelt alle Fahrzeuge in einem Vertrag, vereinfacht die Verwaltung und ermöglicht Mengenrabatte. Neue Fahrzeuge werden unkompliziert hinzugefügt, abgemeldete entfernt.</p>

        <h2>Betriebsunterbrechung — wenn die Arbeit stillsteht</h2>
        <p>Brennt Ihre Werkstatt ab oder wird eine zentrale Maschine zerstört, fallen trotzdem Miete, Löhne und Leasingraten an. Die Betriebsunterbrechungsversicherung ersetzt den entgangenen Gewinn und die laufenden Kosten, bis Ihr Betrieb wieder arbeitsfähig ist.</p>

        <h2>Weitere wichtige Absicherungen</h2>
        <ul>
          <li><strong>Geschäftsinhaltsversicherung</strong> — Schützt Werkzeuge, Maschinen, Materialien und Betriebseinrichtung gegen Feuer, Einbruch, Leitungswasser und Sturm.</li>
          <li><strong>Firmen-Rechtsschutz</strong> — Bei Streitigkeiten mit Auftraggebern über Mängelbeseitigung, mit Lieferanten über defekte Baustoffe oder mit Behörden über Auflagen.</li>
          <li><strong>Betriebliche Altersversorgung</strong> — Ein Instrument zur Mitarbeiterbindung im Fachkräftemangel.</li>
        </ul>
      </div>

      <!-- Product links -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-navy-950 mb-8">Relevante Versicherungen für Handwerksbetriebe</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {relevantProducts.map(product => (
            <a href={product.href} class="group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all no-underline">
              <h3 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">{product.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">{product.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                Mehr erfahren
                <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="mt-16 p-8 bg-navy-900 rounded-2xl text-center">
        <h3 class="text-2xl font-bold text-white mb-3">Betriebscheck für Handwerker</h3>
        <p class="text-slate-300 mb-6">Ich prüfe Ihren betrieblichen Versicherungsschutz auf Lücken und unnötige Doppelversicherungen — kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="inline-flex items-center px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-semibold rounded-lg transition-all hover:shadow-lg hover:shadow-amber-500/25 no-underline">
          Beratungstermin vereinbaren
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Versicherungen für Handwerk & Baubetriebe",
    "description": "Welche Versicherungen brauchen Handwerker und Baubetriebe? Betriebshaftpflicht, Maschinenversicherung, Kfz-Flotte — unabhängige Beratung.",
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</BaseLayout>
