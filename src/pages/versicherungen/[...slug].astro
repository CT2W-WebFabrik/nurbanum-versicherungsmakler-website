---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('versicherungen');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const audienceAnchor = entry.data.audience === 'gewerbe' ? 'gewerbe' : 'privat';

// Privat: map schema category key → label + anchor slug
const privatCategoryMap: Record<string, { label: string; slug: string }> = {
  personen: { label: 'Personenversicherungen', slug: 'personenversicherungen' },
  sach: { label: 'Sachversicherungen', slug: 'sach' },
  haftpflicht: { label: 'Haftpflichtversicherungen', slug: 'haftpflicht' },
  altersvorsorge: { label: 'Altersvorsorge', slug: 'altersvorsorge' },
};

// Gewerbe: map product ID → subcategory label + anchor slug
const gewerbeSubcategoryMap: Record<string, { label: string; slug: string }> = Object.fromEntries([
  ...['betriebshaftpflicht','berufshaftpflicht','dno-versicherung','vermoegensschadenhaftpflicht','produkthaftpflicht','umwelthaftpflicht']
    .map(id => [id, { label: 'Haftpflichtversicherungen', slug: 'haftpflicht' }]),
  ...['betriebsunterbrechung','inhaltsversicherung','betriebsgebaeudeversicherung','firmen-rechtsschutz','cyber']
    .map(id => [id, { label: 'Betriebs- & Sachversicherungen', slug: 'betrieb-sach' }]),
  ...['elektronikversicherung','maschinenversicherung','kfz-flotten']
    .map(id => [id, { label: 'Technik & Fahrzeuge', slug: 'technik-fahrzeuge' }]),
]);

const isGewerbe = entry.data.audience === 'gewerbe';
const resolved = isGewerbe ? gewerbeSubcategoryMap[entry.id] : privatCategoryMap[entry.data.category];
const categoryLabel = resolved?.label ?? 'Gewerbeversicherungen';
const categoryAnchorSlug = resolved?.slug ?? entry.data.category;
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  category={categoryLabel}
  breadcrumbs={[
    { label: 'Versicherungen', href: '/versicherungen/' },
    { label: audienceAnchor === 'gewerbe' ? 'Für Unternehmen' : 'Für Privatpersonen', href: `/versicherungen/#${audienceAnchor}` },
    { label: categoryLabel, href: `/versicherungen/#${audienceAnchor}-${categoryAnchorSlug}` },
  ]}
>
  <Content />

  {/* Service structured data for insurance product pages */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": entry.data.title,
    "description": entry.data.description,
    "provider": { "@id": "https://nurbanum.de/#organization" },
    "serviceType": "Versicherungsvermittlung",
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.4403, "longitude": 10.9553 },
      "geoRadius": "50000"
    }
  })} />
</ArticleLayout>
