---
import { url, slugify } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../config';

const allInsurance = await getCollection('versicherungen');
const sorted = allInsurance.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const privatProducts = sorted.filter(e => e.data.audience === 'privat');
const gewerbeProducts = sorted.filter(e => e.data.audience === 'gewerbe');

const privatCategories: Record<string, { label: string; items: typeof sorted }> = {
  personen: { label: 'Personenversicherungen', items: [] },
  altersvorsorge: { label: 'Altersvorsorge', items: [] },
  sach: { label: 'Sachversicherungen', items: [] },
  haftpflicht: { label: 'Haftpflichtversicherungen', items: [] },
};

for (const entry of privatProducts) {
  const cat = entry.data.category;
  if (privatCategories[cat]) privatCategories[cat].items.push(entry);
}

// Split long Personen section into subsections
const personenItems = privatCategories.personen.items;
const personenCore = personenItems.filter(e =>
  ['berufsunfaehigkeit', 'krankenversicherung', 'risikoleben', 'unfallversicherung', 'pflegeversicherung'].includes(e.id)
);
const personenZusatz = personenItems.filter(e =>
  ['zahnzusatzversicherung', 'krankentagegeld', 'stationaere-zusatzversicherung', 'ambulante-zusatzversicherung', 'heilpraktiker-zusatzversicherung', 'auslandskrankenversicherung'].includes(e.id)
);
const personenSpezial = personenItems.filter(e =>
  ['grundfaehigkeitenversicherung', 'schwere-krankheiten-versicherung', 'kinderabsicherung', 'reiseversicherung', 'sterbegeldversicherung'].includes(e.id)
);

const personenSubsections = [
  { label: 'Kernabsicherung', items: personenCore },
  { label: 'Gesundheitszusatz', items: personenZusatz },
  { label: 'Spezialversicherungen', items: personenSpezial },
];

const allPrivatAccordions = [
  ...personenSubsections.map(sub => ({ slug: slugify(sub.label), label: sub.label, items: sub.items })),
  ...Object.entries(privatCategories)
    .filter(([key]) => key !== 'personen')
    .filter(([, { items }]) => items.length > 0)
    .map(([key, { label, items }]) => ({ slug: slugify(key), label, items })),
];

// Group Gewerbe into subcategories
const gewerbeHaftpflicht = gewerbeProducts.filter(e =>
  ['betriebshaftpflicht', 'berufshaftpflicht', 'dno-versicherung', 'vermoegensschadenhaftpflicht', 'produkthaftpflicht', 'umwelthaftpflicht', 'veranstaltungshaftpflicht'].includes(e.id)
);
const gewerbeBetrieb = gewerbeProducts.filter(e =>
  ['betriebsunterbrechung', 'inhaltsversicherung', 'betriebsgebaeudeversicherung', 'firmen-rechtsschutz', 'cyber', 'warenkreditversicherung', 'vertrauensschadenversicherung', 'bauleistungsversicherung', 'betriebsschliessungsversicherung', 'transportversicherung'].includes(e.id)
);
const gewerbeTechnik = gewerbeProducts.filter(e =>
  ['elektronikversicherung', 'maschinenversicherung', 'kfz-flotten', 'montageversicherung'].includes(e.id)
);

const gewerbeCategories = [
  { slug: 'haftpflicht', label: 'Haftpflichtversicherungen', items: gewerbeHaftpflicht },
  { slug: 'betrieb-sach', label: 'Betriebs- & Sachversicherungen', items: gewerbeBetrieb },
  { slug: 'technik-fahrzeuge', label: 'Technik & Fahrzeuge', items: gewerbeTechnik },
];
---

<BaseLayout
  title="Versicherungen im Überblick — Nurbanum Versicherungsmakler"
  description="Alle Versicherungsarten für Privat und Gewerbe: Haftpflicht, BU, Altersvorsorge, Kfz, Betriebshaftpflicht, D&O und mehr. Unabhängige Beratung."
>
  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Versicherungsschutz</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up" style="animation-delay: 0.1s;">Alle Versicherungen im Überblick</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.2s;">
        Von der Privathaftpflicht bis zur D&O-Versicherung — ich berate Sie unabhängig und finde den optimalen Schutz für Ihre Situation.
      </p>
    </div>
  </section>

  <!-- Sticky navigation: tabs + search -->
  <div class="bg-white border-b border-slate-200 sticky top-16 sm:top-[6.25rem] z-40">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 py-3">
        <nav class="flex gap-1" aria-label="Versicherungskategorien">
          <button
            data-tab="privat"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-amber-100 text-amber-800"
            aria-pressed="true"
          >
            Für Privatpersonen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{privatProducts.length}</span>
          </button>
          <button
            data-tab="gewerbe"
            class="tab-btn px-5 py-2.5 text-sm font-semibold rounded-lg transition-colors whitespace-nowrap bg-slate-50 text-navy-700 hover:text-amber-700 hover:bg-amber-50"
            aria-pressed="false"
          >
            Für Unternehmen
            <span class="ml-1.5 text-xs opacity-70 font-normal">{gewerbeProducts.length}</span>
          </button>
        </nav>
        <div class="sm:ml-auto relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="search"
            id="page-search"
            placeholder="Versicherung suchen…"
            class="w-full sm:w-64 pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-lg bg-slate-50 text-navy-950 placeholder-slate-400 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Privatversicherungen -->
  <section id="privat" data-audience="privat" class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Privatpersonen & Familien</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Privatversicherungen</h2>
      </div>

      {allPrivatAccordions.map((cat, index) => cat.items.length > 0 && (
        <div id={`privat-${cat.slug}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-navy-50/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-privat-${cat.slug}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {cat.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{cat.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-privat-${cat.slug}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {cat.items.map((entry) => (
                  <a
                    href={url(`/versicherungen/${entry.id}/`)}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${entry.data.title} ${entry.data.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {entry.data.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {entry.data.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Versicherung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <!-- Gewerbeversicherungen -->
  <section id="gewerbe" data-audience="gewerbe" class="py-20 sm:py-28 bg-navy-50/50 hidden">
    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-3">Für Unternehmen & Selbständige</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950">Gewerbeversicherungen</h2>
      </div>

      {gewerbeCategories.map((cat, index) => cat.items.length > 0 && (
        <div id={`gewerbe-${cat.slug}`} class="category-accordion mb-2 scroll-mt-28 sm:scroll-mt-40">
          <button
            class="accordion-toggle w-full flex items-center justify-between py-4 px-3 -mx-3 rounded-lg hover:bg-white/50 transition-colors text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
            aria-controls={`content-gewerbe-${cat.slug}`}
          >
            <h3 class="text-xl font-bold text-navy-950 flex items-center">
              <span class="w-8 h-0.5 bg-amber-400 mr-3"></span>
              {cat.label}
              <span class="ml-2 text-sm font-normal text-slate-400">{cat.items.length}</span>
            </h3>
            <svg class="accordion-chevron w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`content-gewerbe-${cat.slug}`} class="accordion-body" data-open={index === 0 ? 'true' : 'false'}>
            <div>
              <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 pt-4 pb-8">
                {cat.items.map((entry) => (
                  <a
                    href={url(`/versicherungen/${entry.id}/`)}
                    class="search-card group block bg-white rounded-xl p-6 border border-slate-100 hover:border-amber-200 hover:shadow-md transition-all duration-300"
                    data-search={`${entry.data.title} ${entry.data.description}`.toLowerCase()}
                  >
                    <h4 class="text-lg font-bold text-navy-950 mb-2 group-hover:text-amber-700 transition-colors">
                      {entry.data.title}
                    </h4>
                    <p class="text-base text-slate-600 leading-relaxed mb-4">
                      {entry.data.description}
                    </p>
                    <span class="inline-flex items-center text-sm font-semibold text-amber-600 group-hover:text-amber-700 transition-colors">
                      Mehr erfahren
                      <svg class="ml-1.5 w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}

      <div class="no-results hidden text-center py-12">
        <p class="text-slate-500 text-lg">Keine passende Versicherung gefunden.</p>
        <button class="clear-search text-amber-600 font-semibold mt-2 hover:text-amber-700 transition-colors">Suche zurücksetzen</button>
      </div>
    </div>
  </section>

  <script>
    import { initTabAccordionSearch } from '../../scripts/tab-accordion-search';
    initTabAccordionSearch({ searchInputId: 'page-search', cardSelector: '.search-card' });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Versicherungen — Nurbanum Versicherungsmakler",
    "description": "Alle Versicherungen im Überblick: Privat- und Gewerbeversicherungen unabhängig verglichen.",
    "publisher": { "@id": `${SITE_URL}/#organization` },
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": sorted.map((entry, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": new URL(url(`/versicherungen/${entry.id}/`), Astro.site).toString()
      }))
    }
  })} />
</BaseLayout>
