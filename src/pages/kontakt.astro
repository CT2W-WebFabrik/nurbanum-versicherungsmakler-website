---
import { url } from '../utils/paths';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt — Nurbanum Versicherungsmakler"
  description="Nehmen Sie Kontakt auf mit Thorsten Schreier, Ihrem unabhängigen Versicherungsmakler in Zirndorf. Telefon, E-Mail, WhatsApp oder Kontaktformular."
>
  <div class="bg-pattern">

    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-800"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_60%,rgba(245,158,11,0.1)_0%,transparent_60%)]"></div>
      <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 text-center">
        <div class="animate-fade-in">
          <h1 class="text-white mb-4">Sprechen wir über Ihre Absicherung</h1>
          <p class="text-xl text-navy-200 max-w-2xl mx-auto">
            Ob Erstberatung, Schadensmeldung oder einfach eine Frage — ich bin für Sie da. Wählen Sie Ihren bevorzugten Kontaktweg.
          </p>
        </div>
      </div>
    </section>

    <div class="max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">

      <!-- Quick Contact Cards -->
      <section class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-20 -mt-10 relative z-10 animate-slide-up">
        <!-- Phone -->
        <a href="tel:+4917384444426" class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md hover:border-amber-300 transition-all no-underline group">
          <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-4 group-hover:bg-amber-500 transition-colors">
            <svg class="w-6 h-6 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </div>
          <h3 class="text-base text-navy-950 mb-1">Anrufen</h3>
          <p class="text-sm text-navy-600 font-medium">0173 8444 4426</p>
        </a>

        <!-- WhatsApp -->
        <a href="https://wa.me/4917384444426?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20eine%20Versicherungsberatung." target="_blank" rel="noopener noreferrer" class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md hover:border-green-300 transition-all no-underline group">
          <div class="w-12 h-12 rounded-xl bg-green-600 flex items-center justify-center mb-4 group-hover:bg-green-500 transition-colors">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <h3 class="text-base text-navy-950 mb-1">WhatsApp</h3>
          <p class="text-sm text-navy-600 font-medium">Nachricht senden</p>
        </a>

        <!-- Email -->
        <a href="mailto:thorsten.schreier@nurbanum.de" class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md hover:border-amber-300 transition-all no-underline group">
          <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-4 group-hover:bg-amber-500 transition-colors">
            <svg class="w-6 h-6 text-amber-400 group-hover:text-navy-950 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-base text-navy-950 mb-1">E-Mail</h3>
          <p class="text-sm text-navy-600 font-medium break-all">thorsten.schreier@nurbanum.de</p>
        </a>

        <!-- Address -->
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
          <div class="w-12 h-12 rounded-xl bg-navy-950 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-base text-navy-950 mb-1">Adresse</h3>
          <p class="text-sm text-navy-600">Hans-Sachs-Straße 2<br>90513 Zirndorf</p>
        </div>
      </section>

      <!-- Main Grid: Form + Sidebar -->
      <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl sm:text-3xl mb-8">Schreiben Sie uns</h2>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden bg-success/10 border border-success/30 rounded-2xl p-8 text-center" role="alert">
            <svg class="w-12 h-12 text-success mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h3 class="text-lg text-navy-950 mb-2">Nachricht gesendet!</h3>
            <p class="text-sm text-slate-600">Vielen Dank für Ihre Anfrage. Ich melde mich in der Regel innerhalb von 24 Stunden bei Ihnen.</p>
          </div>

          <!-- Error message (hidden by default) -->
          <div id="form-error" class="hidden bg-error/10 border border-error/30 rounded-2xl p-6 mb-6" role="alert">
            <p class="text-sm text-error font-medium">Beim Senden ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut oder kontaktieren Sie uns telefonisch unter <a href="tel:+4917384444426" class="underline">0173 8444 4426</a>.</p>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-3 mb-6 flex items-center gap-3">
            <svg class="w-5 h-5 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-sm text-amber-800">Das Kontaktformular ist noch nicht aktiv. Bitte nutzen Sie Telefon, E-Mail oder WhatsApp.</p>
          </div>

          <form
            id="contact-form"
            method="POST"
            class="bg-white rounded-2xl border border-slate-200 p-6 sm:p-10 shadow-sm space-y-6"
            novalidate
          >
            <div class="grid sm:grid-cols-2 gap-6">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-navy-800 mb-2">
                  Name <span class="text-error" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  aria-required="true"
                  autocomplete="name"
                  placeholder="Ihr vollständiger Name"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-navy-900 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-colors"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-navy-800 mb-2">
                  E-Mail <span class="text-error" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  autocomplete="email"
                  placeholder="ihre.email@beispiel.de"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-navy-900 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-colors"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-medium text-navy-800 mb-2">
                  Telefon <span class="text-slate-400 text-xs">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  placeholder="Für Rückruf"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-navy-900 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-colors"
                />
              </div>

              <!-- Subject -->
              <div>
                <label for="subject" class="block text-sm font-medium text-navy-800 mb-2">
                  Betreff
                </label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-colors"
                >
                  <option value="Allgemeine Anfrage">Allgemeine Anfrage</option>
                  <option value="Beratungstermin">Beratungstermin vereinbaren</option>
                  <option value="Schadensmeldung">Schadensmeldung</option>
                  <option value="Rückruf">Rückruf gewünscht</option>
                </select>
              </div>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-navy-800 mb-2">
                Ihre Nachricht <span class="text-error" aria-hidden="true">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                aria-required="true"
                rows="5"
                placeholder="Beschreiben Sie Ihr Anliegen..."
                class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-slate-50 text-navy-900 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-colors resize-y"
              ></textarea>
            </div>

            <!-- Privacy Consent -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                aria-required="true"
                class="mt-1 w-5 h-5 rounded border-slate-300 text-amber-500 focus:ring-amber-400 shrink-0"
              />
              <label for="privacy" class="text-sm text-slate-600 leading-relaxed">
                Ich habe die <a href={url('/datenschutz/')} class="text-navy-600 hover:text-amber-600">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu. <span class="text-error" aria-hidden="true">*</span>
              </label>
            </div>

            <p class="text-xs text-slate-400">Felder mit <span class="text-error">*</span> sind Pflichtfelder.</p>

            <!-- Submit (disabled until form backend is configured) -->
            <button
              type="submit"
              disabled
              aria-disabled="true"
              class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-slate-300 text-slate-500 font-bold rounded-xl cursor-not-allowed"
            >
              Nachricht senden
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
            </button>
          </form>

          <!-- Form submit handler removed — will be re-enabled when form backend is configured -->
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">

          <!-- Opening Hours -->
          <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm">
            <h3 class="text-lg mb-5">Erreichbarkeit</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between items-center py-2 border-b border-slate-100">
                <span class="text-navy-800">Montag — Freitag</span>
                <span class="font-medium text-navy-950">09:00 — 18:00</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-slate-100">
                <span class="text-navy-800">Samstag</span>
                <span class="text-slate-500">nach Vereinbarung</span>
              </div>
              <div class="flex justify-between items-center py-2">
                <span class="text-navy-800">Sonntag</span>
                <span class="text-slate-500">geschlossen</span>
              </div>
            </div>
            <p class="text-xs text-slate-500 mt-4">
              Termine außerhalb der Geschäftszeiten sind nach Absprache möglich.
            </p>
          </div>

          <!-- Quick Actions -->
          <div class="space-y-3">
            <a href="tel:+4917384444426" class="flex items-center gap-4 bg-navy-950 hover:bg-navy-800 text-white rounded-2xl p-5 no-underline transition-colors group">
              <div class="w-11 h-11 rounded-xl bg-amber-500/20 flex items-center justify-center shrink-0 group-hover:bg-amber-500/30 transition-colors">
                <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <span class="text-sm font-bold block">Jetzt anrufen</span>
                <span class="text-xs text-navy-300">0173 8444 4426</span>
              </div>
            </a>

            <a href="https://wa.me/4917384444426?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20eine%20Versicherungsberatung." target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 bg-green-600 hover:bg-green-500 text-white rounded-2xl p-5 no-underline transition-colors group">
              <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-white/20 transition-colors">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <span class="text-sm font-bold block">Per WhatsApp schreiben</span>
                <span class="text-xs text-green-100">Schnell und unkompliziert</span>
              </div>
            </a>
          </div>

          <!-- Google Maps (2-Click Consent) -->
          <div id="map-container" class="rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
            <div id="map-placeholder" class="bg-white p-8 text-center">
              <div class="w-14 h-14 rounded-full bg-navy-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-7 h-7 text-navy-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
              </div>
              <p class="text-sm font-medium text-navy-950 mb-1">Hans-Sachs-Straße 2, 90513 Zirndorf</p>
              <p class="text-xs text-slate-500 mb-4 leading-relaxed">
                Beim Laden der Karte werden Daten an Google übertragen.
                <a href={url('/datenschutz/#google-maps')} class="text-navy-600 hover:text-amber-600">Mehr erfahren</a>
              </p>
              <button
                id="load-map-btn"
                type="button"
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-amber-500 hover:bg-amber-400 text-navy-950 text-sm font-bold rounded-xl transition-colors shadow-sm cursor-pointer"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                Karte laden
              </button>
            </div>
          </div>

          <script>
            function loadMap() {
              const container = document.getElementById('map-container');
              const placeholder = document.getElementById('map-placeholder');
              if (!container || !placeholder) return;

              placeholder.remove();
              const iframe = document.createElement('iframe');
              iframe.src = 'https://www.google.com/maps?q=Hans-Sachs-Stra%C3%9Fe+2,+90513+Zirndorf&output=embed';
              iframe.width = '100%';
              iframe.height = '300';
              iframe.style.border = '0';
              iframe.loading = 'lazy';
              iframe.referrerPolicy = 'no-referrer-when-downgrade';
              iframe.setAttribute('allowfullscreen', '');
              iframe.title = 'Google Maps — Hans-Sachs-Straße 2, 90513 Zirndorf';
              container.appendChild(iframe);

              localStorage.setItem('nurbanum-maps-consent', 'true');
            }

            const btn = document.getElementById('load-map-btn');
            btn?.addEventListener('click', loadMap);

            if (localStorage.getItem('nurbanum-maps-consent') === 'true') {
              loadMap();
            }
          </script>

        </div>
      </div>

    </div>
  </div>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "mainEntity": { "@id": "https://nurbanum.de/#organization" }
  })} />
</BaseLayout>
