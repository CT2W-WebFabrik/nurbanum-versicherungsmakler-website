---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import { slugify } from '../../utils/paths';
import { extractFaqFromMarkdown, buildFaqSchema } from '../../utils/faq';

export async function getStaticPaths() {
  const entries = await getCollection('ratgeber');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const audience = entry.data.audience ?? 'privat';
const faqSchema = buildFaqSchema(extractFaqFromMarkdown(entry.body ?? ''));
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  category={entry.data.category}
  readingTime={entry.data.readingTime}
  faqSchema={faqSchema}
  breadcrumbs={[
    { label: 'Ratgeber', href: '/ratgeber/' },
    { label: audience === 'gewerbe' ? 'Für Unternehmen' : 'Für Privatpersonen', href: `/ratgeber/#${audience}` },
    { label: entry.data.category, href: `/ratgeber/#${audience}-${slugify(entry.data.category)}` },
  ]}
>
  <Content />
</ArticleLayout>
