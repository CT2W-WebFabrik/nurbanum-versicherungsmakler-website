---
import { url } from '../../utils/paths';
import BaseLayout from '../../layouts/BaseLayout.astro';

const cities = [
  {
    name: "Zirndorf",
    subtitle: "Unser Standort",
    description: "Sitz in der Hans-Sachs-Straße 2 — persönliche Beratung direkt vor Ort, mitten im Rangau.",
    href: "/standorte/zirndorf/",
    highlight: true,
  },
  {
    name: "Nürnberg",
    subtitle: "Frankenmetropole",
    description: "Gewerbe- und Privatversicherung für Nürnberger Unternehmen, Freiberufler und Haushalte — mit Hausbesuchen vor Ort.",
    href: "/standorte/nuernberg/",
    highlight: false,
  },
  {
    name: "Fürth",
    subtitle: "Direkte Nachbarstadt",
    description: "Nur wenige Minuten von Zirndorf entfernt: unabhängige Versicherungsberatung für den Fürther Mittelstand und Privathaushalte.",
    href: "/standorte/fuerth/",
    highlight: false,
  },
];
---

<BaseLayout
  title="Standorte & Einzugsgebiet — Nurbanum Versicherungsmakler"
  description="Nurbanum Versicherungsmakler in Zirndorf berät Kunden in der gesamten Metropolregion Nürnberg: Zirndorf, Nürnberg, Fürth und Umgebung."
>

  <section class="bg-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950/90 via-navy-900/80 to-navy-800/70"></div>
    <div class="relative max-w-[1440px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <p class="text-amber-400 text-sm font-semibold tracking-widest uppercase mb-4 animate-fade-in">Standort & Einzugsgebiet</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 animate-slide-up">Ihr Versicherungsmakler in der Metropolregion Nürnberg</h1>
      <p class="text-lg text-slate-300 max-w-2xl animate-slide-up" style="animation-delay: 0.1s;">Sitz in Zirndorf, aktiv in der gesamten Region. Unabhängige Beratung — persönlich bei Ihnen vor Ort, im Büro oder per Video.</p>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-amber-700 text-sm font-semibold tracking-widest uppercase mb-4">Regionale Präsenz</p>
        <h2 class="text-2xl sm:text-3xl font-800 text-navy-950 mb-6">Wo wir für Sie da sind</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {cities.map((city) => (
          <a
            href={url(city.href)}
            class:list={[
              "group block p-7 rounded-2xl border transition-all hover:shadow-xl hover:-translate-y-0.5 no-underline",
              city.highlight
                ? "bg-navy-950 border-navy-800 hover:border-amber-400"
                : "bg-slate-50 border-slate-100 hover:border-amber-300"
            ]}
          >
            <p class:list={[
              "text-xs font-semibold tracking-widest uppercase mb-2",
              city.highlight ? "text-amber-400" : "text-amber-700"
            ]}>{city.subtitle}</p>
            <h3 class:list={[
              "text-xl font-bold mb-3 transition-colors",
              city.highlight
                ? "text-white group-hover:text-amber-400"
                : "text-navy-950 group-hover:text-amber-700"
            ]}>{city.name}</h3>
            <p class:list={[
              "text-sm leading-relaxed mb-4",
              city.highlight ? "text-slate-300" : "text-slate-600"
            ]}>{city.description}</p>
            <span class:list={[
              "inline-flex items-center text-sm font-semibold transition-colors",
              city.highlight
                ? "text-amber-400 group-hover:text-amber-300"
                : "text-amber-600 group-hover:text-amber-500"
            ]}>
              Mehr erfahren
              <svg class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="bg-slate-50 rounded-2xl border border-slate-100 p-8 sm:p-10">
        <h3 class="text-xl font-bold text-navy-950 mb-6">Einzugsgebiet auf einen Blick</h3>
        <div class="grid sm:grid-cols-2 gap-8">
          <div>
            <h4 class="font-semibold text-navy-900 mb-3">Städte & Gemeinden</h4>
            <ul class="space-y-2 text-slate-600 text-sm">
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-500 shrink-0"></span>Zirndorf <span class="text-slate-400">(Bürostandort)</span></li>
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-500 shrink-0"></span>Nürnberg</li>
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-500 shrink-0"></span>Fürth</li>
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>Oberasbach, Stein, Roßtal</li>
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>Cadolzburg, Langenzenn</li>
              <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-slate-300 shrink-0"></span>Erlangen, Schwabach</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold text-navy-900 mb-3">So erreichen Sie uns</h4>
            <ul class="space-y-3 text-slate-600 text-sm">
              <li>Hans-Sachs-Straße 2, 90513 Zirndorf</li>
              <li>Mo – Fr: 09:00 – 18:00 Uhr</li>
              <li>Tel: <a href="tel:+4917384444426" class="text-amber-600 hover:text-amber-700 no-underline">0173 8444 4426</a></li>
              <li>E-Mail: <a href="mailto:thorsten.schreier@nurbanum.de" class="text-amber-600 hover:text-amber-700 no-underline">thorsten.schreier@nurbanum.de</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none prose-headings:text-navy-950 prose-a:text-amber-600">
        <h2>Warum ein regionaler Versicherungsmakler?</h2>
        <p>Online-Vergleichsrechner liefern Ergebnisse in Sekunden, aber sie kennen weder Ihren konkreten Bedarf noch die Besonderheiten der Region. Als Makler in der Metropolregion Nürnberg kenne ich die lokale Wirtschaftsstruktur, die typischen Risiken der hier ansässigen Branchen und die Lebensrealitäten der Menschen — vom jungen Paar mit erstem Eigenheim in Zirndorf bis zum Nürnberger IT-Dienstleister mit 20 Mitarbeitern.</p>
        <p>Was mich von einem Versicherungsvertreter unterscheidet: Ich bin vertraglich an keine Gesellschaft gebunden. Ich vergleiche den gesamten Markt und empfehle nur das, was sich für Sie tatsächlich lohnt. Die Beratung selbst ist für Sie kostenlos.</p>
        <h3>Persönlich erreichbar, wenn es zählt</h3>
        <p>Der größte Vorteil eines regionalen Maklers zeigt sich im Schadenfall: Wenn der Keller nach einem Starkregen unter Wasser steht oder ein Einbruch in Ihrem Betrieb passiert, bin ich in kurzer Zeit vor Ort. Kein Callcenter, keine Warteschleife — ein Ansprechpartner, den Sie kennen.</p>
      </div>
    </div>
  </section>

  <section class="py-20 sm:py-28 bg-pattern">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-navy-950 to-navy-800 rounded-3xl p-10 sm:p-14 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(245,158,11,0.15)_0%,transparent_60%)]"></div>
        <div class="relative">
          <h2 class="text-2xl sm:text-3xl font-800 text-white mb-6">Beratung in Ihrer Nähe vereinbaren</h2>
          <p class="text-lg text-navy-200 max-w-xl mx-auto mb-8">Egal ob Zirndorf, Nürnberg oder Fürth — das Erstgespräch ist kostenlos und unverbindlich.</p>
          <a href={url('/kontakt/')} class="inline-flex items-center gap-2 px-8 py-4 bg-amber-500 hover:bg-amber-400 text-navy-950 font-bold rounded-xl transition-all shadow-lg shadow-amber-500/25 hover:shadow-amber-400/35 no-underline">
            Kontakt aufnehmen
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
